<%# Admin — Invite Employee %>

<div class="max-w-lg">
  <div class="flex items-center gap-2 text-sm text-gray-400 mb-7">
    <%= link_to "Team Members", admin_company_memberships_path(@current_company.slug),
          class: "hover:text-gray-600 transition-colors" %>
    <span>/</span>
    <span class="text-gray-700 font-medium">Invite employee</span>
  </div>

  <h1 class="text-2xl font-semibold text-gray-900 mb-2">Invite Employee</h1>
  <p class="text-sm text-gray-500 mb-8">
    Enter the employee's details. They'll receive an email with a link to create their NestSave account.
  </p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <%= form_with model: @membership,
          url: admin_company_memberships_path(@current_company.slug),
          method: :post do |f| %>

      <% if @membership.errors.any? %>
        <div class="mb-5 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
          <p class="text-sm font-semibold text-red-700 mb-1">Please fix the following:</p>
          <ul class="list-disc list-inside space-y-0.5">
            <% @membership.errors.full_messages.each do |msg| %>
              <li class="text-sm text-red-600"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-5">
        <%# Personal details %>
        <div>
          <%= label_tag "company_membership[full_name]", "Full name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= text_field_tag "company_membership[full_name]", params.dig(:company_membership, :full_name),
                placeholder: "Jane Smith",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>

        <div>
          <%= label_tag "company_membership[email]", "Work email address", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= text_field_tag "company_membership[email]", params.dig(:company_membership, :email),
                type: :email, placeholder: "jane@company.com",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          <p class="text-xs text-gray-400 mt-1">The invitation link will be sent to this address</p>
        </div>

        <hr class="border-gray-100">

        <%# Employment info — feeds HR::CreateEmployeeProfileService %>
        <div>
          <%= f.label :job_title, "Job title", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :job_title, placeholder: "e.g. Software Engineer",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>

        <div>
          <%= label_tag "company_membership[department_id]", "Department", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= select_tag "company_membership[department_id]",
                options_for_select(
                  @current_company.departments.active.order(:name).map { |d| [d.name, d.id] },
                  params.dig(:company_membership, :department_id)
                ),
                include_blank: "— Select department —",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition bg-white" %>
        </div>

        <div>
          <%= label_tag "company_membership[team_id]", "Team (optional)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= select_tag "company_membership[team_id]",
                options_for_select(
                  @teams.map { |t| [t.name, t.id] },
                  params.dig(:company_membership, :team_id)
                ),
                include_blank: "Company-wide (no team)",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition bg-white" %>
          <p class="text-xs text-gray-400 mt-1">Leave blank for HR, social media managers and other company-wide staff</p>
        </div>

        <div>
          <%= f.label :employment_type, "Employment type", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.select :employment_type,
                [["Full time", "full_time"], ["Part time", "part_time"], ["Contractor", "contractor"]],
                {},
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition bg-white" %>
        </div>

        <div>
          <%= f.label :employment_start_date, "Start date", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.date_field :employment_start_date,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>

        <div>
          <%= f.label :initial_salary, "Starting salary (#{currency_symbol}/month)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm font-medium"><%= currency_symbol %></span>
            <%= f.number_field :initial_salary, min: 1, step: "0.01", placeholder: "3000.00",
                  class: "block w-full rounded-lg border border-gray-300 pl-7 pr-3 py-2.5 text-sm placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 mt-6">
        <%= f.submit "Send invitation",
              class: "bg-primary-500 hover:bg-primary-600 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors cursor-pointer" %>
        <%= link_to "Cancel", admin_company_memberships_path(@current_company.slug),
              class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors px-2 py-2" %>
      </div>
    <% end %>
  </div>
</div>
