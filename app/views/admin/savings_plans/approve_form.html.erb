<%# Admin — Approve Savings Plan (modal) %>

<turbo-frame id="modal">
  <div class="p-6">
    <div class="flex items-start justify-between mb-5">
      <div>
        <h2 class="text-lg font-semibold text-gray-900">Approve Savings Plan</h2>
        <p class="text-sm text-gray-500 mt-0.5">
          <%= @plan.user.full_name %> &mdash; <%= @plan.name %>
        </p>
      </div>
      <button data-action="modal#close"
              class="text-gray-400 hover:text-gray-600 transition-colors p-1 -mr-1 rounded-lg hover:bg-gray-100">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="bg-emerald-50 border border-emerald-100 rounded-xl px-4 py-3 mb-5">
      <p class="text-xs font-semibold text-emerald-700 uppercase tracking-wider mb-2">Plan summary</p>
      <div class="flex justify-between text-sm mb-1">
        <span class="text-emerald-700">Monthly deduction</span>
        <span class="font-semibold text-emerald-800"><%= gbp(@plan.monthly_amount) %></span>
      </div>
      <div class="flex justify-between text-sm mb-1">
        <span class="text-emerald-700">Duration</span>
        <span class="font-semibold text-emerald-800"><%= @plan.duration_months %> months</span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-emerald-700">Target</span>
        <span class="font-semibold text-emerald-800"><%= gbp(@plan.target_amount) %></span>
      </div>
    </div>

    <%= form_with url: approve_admin_savings_plan_path(@current_company.slug, @plan),
          method: :patch do |f| %>
      <div class="mb-5">
        <%= label_tag :note, "Note (optional)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= text_area_tag :note, nil,
              rows: 3,
              placeholder: "Any notes for the employee...",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition resize-none" %>
      </div>
      <div class="flex gap-3">
        <%= f.submit "Approve plan",
              class: "flex-1 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold px-4 py-2.5 rounded-xl text-sm transition-colors cursor-pointer text-center" %>
        <button type="button" data-action="modal#close"
                class="px-4 py-2.5 rounded-xl text-sm font-medium text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-colors">
          Cancel
        </button>
      </div>
    <% end %>
  </div>
</turbo-frame>
