<%# Admin — Edit Employee Profile %>

<div class="max-w-2xl">
  <div class="flex items-center gap-2 text-sm text-gray-400 mb-7">
    <%= link_to "Employees", admin_employee_profiles_path(@current_company.slug),
          class: "hover:text-gray-600 transition-colors" %>
    <span>/</span>
    <%= link_to @profile.company_membership.display_name,
          admin_employee_profile_path(@current_company.slug, @profile),
          class: "hover:text-gray-600 transition-colors" %>
    <span>/</span>
    <span class="text-gray-700 font-medium">Edit</span>
  </div>

  <h1 class="text-2xl font-semibold text-gray-900 mb-8">Edit Profile</h1>

  <%= form_with model: @profile,
        url: admin_employee_profile_path(@current_company.slug, @profile),
        method: :patch do |f| %>

    <% if @profile.errors.any? %>
      <div class="mb-6 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
        <p class="text-sm font-semibold text-red-700 mb-1">Please fix the following:</p>
        <ul class="list-disc list-inside space-y-0.5">
          <% @profile.errors.full_messages.each do |msg| %>
            <li class="text-sm text-red-600"><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# Personal details %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-5">
      <h2 class="text-sm font-semibold text-gray-900 mb-5">Personal details</h2>
      <div class="grid grid-cols-2 gap-x-5 gap-y-4">
        <div>
          <%= f.label :preferred_name, "Preferred name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :preferred_name, placeholder: "e.g. Seun",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :gender, "Gender", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :gender, placeholder: "e.g. Female",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :date_of_birth, "Date of birth", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.date_field :date_of_birth,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :nationality, "Nationality", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :nationality, placeholder: "e.g. British",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :phone, "Phone", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.telephone_field :phone, placeholder: "+44 7700 900000",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :personal_email, "Personal email", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.email_field :personal_email, placeholder: "personal@example.com",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
      </div>
    </div>

    <%# Employment details %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-5">
      <h2 class="text-sm font-semibold text-gray-900 mb-5">Employment</h2>
      <div class="grid grid-cols-2 gap-x-5 gap-y-4">
        <div>
          <%= f.label :job_title, "Job title", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :job_title, placeholder: "e.g. Software Engineer",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :department_id, "Department", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.select :department_id,
                options_for_select(
                  @current_company.departments.active.order(:name).map { |d| [d.name, d.id] },
                  @profile.department_id
                ),
                { include_blank: "— Select department —" },
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition bg-white" %>
        </div>
        <div>
          <%= f.label :employment_type, "Employment type", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.select :employment_type,
                [["Full time", "full_time"], ["Part time", "part_time"], ["Contractor", "contractor"]],
                {},
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition bg-white" %>
        </div>
        <div>
          <%= f.label :employment_start_date, "Start date", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.date_field :employment_start_date,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :employment_end_date, "End date", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.date_field :employment_end_date,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          <p class="text-xs text-gray-400 mt-1">Leave blank if currently employed</p>
        </div>
      </div>
    </div>

    <%# Right to work %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-5">
      <h2 class="text-sm font-semibold text-gray-900 mb-5">Right to work</h2>
      <div class="grid grid-cols-2 gap-x-5 gap-y-4">
        <div>
          <%= f.label :right_to_work_status, "Status", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :right_to_work_status, placeholder: "e.g. British Citizen",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :right_to_work_expiry, "Expiry date", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.date_field :right_to_work_expiry,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          <p class="text-xs text-gray-400 mt-1">Leave blank if indefinite</p>
        </div>
      </div>
    </div>

    <%# Address %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
      <h2 class="text-sm font-semibold text-gray-900 mb-5">Address</h2>
      <div class="space-y-4">
        <div>
          <%= f.label :address_line_1, "Address line 1", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :address_line_1, placeholder: "123 High Street",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :address_line_2, "Address line 2", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :address_line_2,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div class="grid grid-cols-2 gap-5">
          <div>
            <%= f.label :city, "City", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.text_field :city, placeholder: "London",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          </div>
          <div>
            <%= f.label :postcode, "Postcode", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.text_field :postcode, placeholder: "EC1A 1BB",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          </div>
        </div>
        <div>
          <%= f.label :country, "Country", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :country,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit "Save changes",
            class: "bg-primary-500 hover:bg-primary-600 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors cursor-pointer" %>
      <%= link_to "Cancel",
            admin_employee_profile_path(@current_company.slug, @profile),
            class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors px-2 py-2" %>
    </div>
  <% end %>
</div>
