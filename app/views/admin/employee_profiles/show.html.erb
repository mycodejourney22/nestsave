              <td class="px-5 py-4 text-right">
                <div class="flex items-center gap-3 justify-end">
                  <% if doc.file.attached? %>
                    <%= link_to "View", doc.file_url,
                          target: "_blank", rel: "noopener noreferrer",
                          class: "text-xs font-medium text-primary-600 hover:text-primary-700" %>
                    <%= link_to "Download", doc.download_url,
                          target: "_blank", rel: "noopener noreferrer",
                          class: "text-xs font-medium text-gray-600 hover:text-gray-700" %>
                    <span class="text-xs text-gray-400"><%= doc.file_size_display %></span>
                  <% end %>
                  <%= link_to "Remove",
                        admin_employee_profile_document_path(@current_company.slug, @profile, doc),
                        data: { turbo_method: :delete, turbo_confirm: "Remove this document?" },
                        class: "text-xs font-medium text-red-600 hover:text-red-700" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

