<div class="flex items-center justify-between mb-3">
  <h2 class="text-base font-semibold text-gray-900">
    Actions needed
    <% if pending_actions.any? %>
      <span class="ml-1.5 inline-flex items-center rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-600/20">
        <%= pending_actions.size %>
      </span>
    <% end %>
  </h2>
</div>

<% if pending_actions.empty? %>
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm flex flex-col items-center justify-center py-16 text-center px-8">
    <div class="w-12 h-12 rounded-2xl bg-emerald-50 flex items-center justify-center mb-3">
      <svg class="w-6 h-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>
    <p class="text-sm font-semibold text-gray-900 mb-1">All caught up</p>
    <p class="text-xs text-gray-400">No pending approvals or alerts.</p>
  </div>
<% else %>
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm divide-y divide-gray-100 overflow-hidden">
    <% pending_actions.each do |action| %>
      <div class="flex items-center gap-4 px-5 py-4 hover:bg-gray-50/60 transition-colors">
        <%# Type badge %>
        <span class="inline-flex items-center rounded-lg px-2.5 py-1 text-xs font-semibold flex-shrink-0 <%= action[:badge_color] %>">
          <%= action[:badge] %>
        </span>

        <%# Details %>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-gray-900 truncate"><%= action[:employee_name] %></p>
          <p class="text-xs text-gray-400 truncate"><%= action[:title] %></p>
        </div>

        <%# Date %>
        <p class="text-xs text-gray-400 flex-shrink-0 hidden sm:block whitespace-nowrap">
          <%= action[:date]&.strftime("%d %b") %>
        </p>

        <%# Actions %>
        <div class="flex items-center gap-1.5 flex-shrink-0">
          <% if action[:approve_path] %>
            <%= link_to "Approve",
                  action[:approve_path],
                  data: { turbo_frame: "modal" },
                  class: "text-xs font-semibold text-emerald-700 hover:text-emerald-900 bg-emerald-50 hover:bg-emerald-100 px-2.5 py-1.5 rounded-lg transition-colors" %>
            <%= link_to "Decline",
                  action[:decline_path],
                  data: { turbo_frame: "modal" },
                  class: "text-xs font-semibold text-red-700 hover:text-red-900 bg-red-50 hover:bg-red-100 px-2.5 py-1.5 rounded-lg transition-colors" %>
          <% elsif action[:path] %>
            <%= link_to "View",
                  action[:path],
                  class: "text-xs font-semibold text-primary-700 hover:text-primary-900 bg-primary-50 hover:bg-primary-100 px-2.5 py-1.5 rounded-lg transition-colors" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
