<%# Admin — Dashboard %>

<%# ── Greeting ────────────────────────────────────────────────── %>
<div class="mb-7">
  <h1 class="text-2xl font-semibold text-gray-900">
    Good <%= Time.current.hour < 12 ? "morning" : Time.current.hour < 17 ? "afternoon" : "evening" %>,
    <%= current_user.full_name.split.first %>
  </h1>
  <p class="text-gray-500 text-sm mt-1">
    <%= @current_company.name %>
    &middot; <%= Date.current.strftime("%A, %-d %B %Y") %>
    <% if @current_company.payroll_day.present? %>
      &middot; Payroll runs on the <%= @current_company.payroll_day.ordinalize %>
    <% end %>
  </p>
</div>

<%# ── Hero stat cards ─────────────────────────────────────────── %>
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Total employees</p>
    <p class="text-3xl font-bold text-gray-900"><%= @total_employees %></p>
    <p class="text-xs text-gray-400 mt-1">active members</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">On leave today</p>
    <p class="text-3xl font-bold <%= @on_leave_today > 0 ? "text-amber-600" : "text-gray-900" %>">
      <%= @on_leave_today %>
    </p>
    <p class="text-xs text-gray-400 mt-1"><%= @on_leave_today == 1 ? "person" : "people" %> out today</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Pending actions</p>
    <p class="text-3xl font-bold <%= @pending_count > 0 ? "text-red-600" : "text-gray-900" %>">
      <%= @pending_count %>
    </p>
    <p class="text-xs text-gray-400 mt-1"><%= @pending_count == 1 ? "item needs" : "items need" %> attention</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Invites pending</p>
    <p class="text-3xl font-bold <%= @pending_invites > 0 ? "text-amber-600" : "text-gray-900" %>">
      <%= @pending_invites %>
    </p>
    <p class="text-xs text-gray-400 mt-1">awaiting acceptance</p>
  </div>
</div>

<%# ── Needs your attention ────────────────────────────────────── %>
<div class="mb-8">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-base font-semibold text-gray-900">
      Needs your attention
      <% if @pending_count > 0 %>
        <span class="ml-1.5 inline-flex items-center rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/20">
          <%= @pending_count %>
        </span>
      <% end %>
    </h2>
  </div>

  <% if @pending_actions.empty? %>
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm flex flex-col items-center justify-center py-14 text-center px-8">
      <div class="w-12 h-12 rounded-2xl bg-emerald-50 flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <p class="text-sm font-semibold text-gray-900 mb-1">All caught up</p>
      <p class="text-xs text-gray-400">No pending approvals or alerts.</p>
    </div>
  <% else %>
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm divide-y divide-gray-100 overflow-hidden">
      <% @pending_actions.each do |action| %>
        <%
          dot_color = case action[:priority]
            when :high   then "bg-red-500"
            when :medium then "bg-amber-400"
            else              "bg-teal-400"
          end
          badge_color = case action[:type]
            when :leave   then "bg-blue-50 text-blue-700 ring-blue-600/20"
            when :advance then "bg-purple-50 text-purple-700 ring-purple-600/20"
            when :savings then "bg-emerald-50 text-emerald-700 ring-emerald-600/20"
            else               "bg-amber-50 text-amber-700 ring-amber-600/20"
          end
          badge_label = case action[:type]
            when :leave   then "Leave"
            when :advance then "Advance"
            when :savings then "Savings"
            else               "HR"
          end
        %>
        <div class="flex items-start gap-3 px-4 py-4 hover:bg-gray-50/60 transition-colors">
          <%# Priority dot %>
          <div class="w-2 h-2 rounded-full flex-shrink-0 mt-1.5 <%= dot_color %>"></div>

          <%# Details %>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-0.5 flex-wrap">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= action[:name] %></p>
              <span class="inline-flex items-center rounded-full px-1.5 py-0.5 text-xs font-medium ring-1 ring-inset flex-shrink-0 <%= badge_color %>">
                <%= badge_label %>
              </span>
            </div>
            <p class="text-xs text-gray-600 truncate"><%= action[:description] %></p>
            <p class="text-xs text-gray-400 mt-0.5"><%= action[:sub] %> &middot; <%= time_ago_in_words(action[:time]) %> ago</p>
            <%# Actions inline on mobile %>
            <div class="flex items-center gap-1.5 mt-2">
              <% if action[:approvable] %>
                <%= link_to "Approve",
                      action[:approve_path],
                      data: { turbo_frame: "modal" },
                      class: "text-xs font-semibold text-emerald-700 bg-emerald-50 hover:bg-emerald-100 px-2.5 py-1.5 rounded-lg transition-colors min-h-[36px] flex items-center" %>
                <%= link_to "Decline",
                      action[:decline_path],
                      data: { turbo_frame: "modal" },
                      class: "text-xs font-semibold text-red-700 bg-red-50 hover:bg-red-100 px-2.5 py-1.5 rounded-lg transition-colors min-h-[36px] flex items-center" %>
              <% elsif action[:action_path] %>
                <%= link_to action[:action_label],
                      action[:action_path],
                      class: "text-xs font-semibold text-primary-700 bg-primary-50 hover:bg-primary-100 px-2.5 py-1.5 rounded-lg transition-colors min-h-[36px] flex items-center" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<%# ── Teams ───────────────────────────────────────────────────── %>
<div class="mb-8">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-base font-semibold text-gray-900">Teams</h2>
    <%= link_to "Manage teams",
          admin_teams_path(@current_company.slug),
          class: "text-xs font-medium text-primary-600 hover:text-primary-700" %>
  </div>

  <% if @teams_overview.empty? %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm flex flex-col items-center justify-center py-10 text-center px-8">
      <p class="text-sm font-medium text-gray-700 mb-1">No teams set up yet</p>
      <%= link_to "Create a team",
            new_admin_team_path(@current_company.slug),
            class: "text-xs font-medium text-primary-600 hover:text-primary-700" %>
    </div>
  <% else %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm divide-y divide-gray-100 overflow-hidden">
      <% @teams_overview.each do |t| %>
        <div class="flex items-center justify-between px-5 py-3.5 hover:bg-gray-50/60 transition-colors">
          <div>
            <%= link_to t[:team].name,
                  admin_team_path(@current_company.slug, t[:team]),
                  class: "text-sm font-semibold text-gray-900 hover:text-primary-600 transition-colors" %>
            <p class="text-xs text-gray-400 mt-0.5">
              <%= t[:member_count] %> <%= "member".pluralize(t[:member_count]) %>
              <% if t[:on_leave] > 0 %>
                &middot; <span class="text-amber-600"><%= t[:on_leave] %> on leave</span>
              <% end %>
            </p>
          </div>
          <% rota_label, rota_class = case t[:rota_status]
               when "published" then ["Rota published", "text-gray-400"]
               when "draft"     then ["Rota draft",     "text-amber-500"]
               else                  ["No rota",        "text-gray-300"]
             end %>
          <span class="text-xs font-medium <%= rota_class %>"><%= rota_label %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<div class="h-px bg-gray-100 mb-8"></div>

<%# ── Financial snapshot ───────────────────────────────────────── %>
<div>
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">
      Financial snapshot &middot; <%= Date.current.strftime("%B %Y") %>
    </h2>
    <%= link_to "Full payroll report",
          admin_dashboard_path(@current_company.slug),
          class: "text-xs font-medium text-primary-600 hover:text-primary-700" %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
      <p class="text-xs font-medium text-gray-400 mb-1">Savings deductions</p>
      <p class="text-base font-bold text-gray-900"><%= gbp(@financial[:savings_deductions]) %></p>
      <p class="text-xs text-gray-400 mt-0.5"><%= @financial[:active_savers] %> active savers</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
      <p class="text-xs font-medium text-gray-400 mb-1">Advance repayments</p>
      <p class="text-base font-bold text-gray-900"><%= gbp(@financial[:advance_repayments]) %></p>
      <p class="text-xs text-gray-400 mt-0.5">this month</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:col-span-2 lg:col-span-1">
      <p class="text-xs font-medium text-gray-400 mb-1">Total deductions</p>
      <p class="text-base font-bold text-primary-600">
        <%= gbp(@financial[:savings_deductions] + @financial[:advance_repayments]) %>
      </p>
      <p class="text-xs text-gray-400 mt-0.5">savings + repayments</p>
    </div>
  </div>
</div>
