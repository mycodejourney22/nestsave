<%# Admin — Dashboard %>

<%# Page header %>
<div class="mb-8">
  <h1 class="text-2xl font-semibold text-gray-900">
    Good <%= Time.current.hour < 12 ? "morning" : Time.current.hour < 17 ? "afternoon" : "evening" %>,
    <%= current_user.full_name.split.first %>
  </h1>
  <p class="text-gray-500 text-sm mt-1"><%= @current_company.name %> &middot; <%= Date.current.strftime("%A, %-d %B %Y") %></p>
</div>

<%# Stats row %>
<div class="grid grid-cols-2 lg:grid-cols-6 gap-4 mb-8">
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 lg:col-span-2">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Savings this month</p>
    <p class="text-2xl font-bold text-gray-900"><%= gbp(@monthly_summary[:savings_total]) %></p>
    <p class="text-xs text-gray-400 mt-1"><%= @monthly_summary[:active_savers] %> active savers</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 lg:col-span-2">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Advance repayments</p>
    <p class="text-2xl font-bold text-gray-900"><%= gbp(@monthly_summary[:advance_repayments]) %></p>
    <p class="text-xs text-gray-400 mt-1"><%= @monthly_summary[:active_advances] %> active advances</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Headcount</p>
    <p class="text-2xl font-bold text-gray-900"><%= @monthly_summary[:headcount] %></p>
    <p class="text-xs text-gray-400 mt-1">active members</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Pending invites</p>
    <p class="text-2xl font-bold text-gray-900"><%= @monthly_summary[:pending_invites] %></p>
    <p class="text-xs text-gray-400 mt-1">awaiting acceptance</p>
  </div>
</div>

<div class="grid lg:grid-cols-5 gap-6">

  <%# ── Pending actions — 3 cols ─────────────────────────────── %>
  <div class="lg:col-span-3">
    <div id="pending_actions">
      <%= render "admin/dashboard/pending_actions", pending_actions: @pending_actions %>
    </div>
  </div>

  <%# ── Recent activity — 2 cols ─────────────────────────────── %>
  <div class="lg:col-span-2">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold text-gray-900">Recent activity</h2>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <% if @recent_activity.empty? %>
        <div class="flex flex-col items-center justify-center py-12 text-center px-6">
          <p class="text-sm text-gray-400">No transactions yet</p>
        </div>
      <% else %>
        <ul class="divide-y divide-gray-100">
          <% @recent_activity.each do |tx| %>
            <li class="flex items-center gap-3 px-5 py-3.5">
              <div class="w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0
                          <%= %w[savings_withdrawal advance_disbursement].include?(tx.kind) ? "bg-red-50" : "bg-emerald-50" %>">
                <svg class="w-3.5 h-3.5 <%= %w[savings_withdrawal advance_disbursement].include?(tx.kind) ? "text-red-500" : "text-emerald-600" %>"
                     fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <% if %w[savings_withdrawal advance_disbursement].include?(tx.kind) %>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18"/>
                  <% else %>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"/>
                  <% end %>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-medium text-gray-800 truncate"><%= kind_label(tx.kind) %></p>
                <p class="text-xs text-gray-400"><%= tx.created_at.strftime("%d %b %Y") %></p>
              </div>
              <p class="text-xs font-semibold flex-shrink-0 <%= kind_color(tx.kind) %>">
                <%= kind_sign(tx.kind) %><%= gbp(tx.amount) %>
              </p>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>

    <%# This month summary card %>
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5 mt-4">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">
        This month &middot; <%= Date.current.strftime("%B %Y") %>
      </p>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">Savings deducted</span>
          <span class="text-sm font-semibold text-gray-900"><%= gbp(@monthly_summary[:savings_total]) %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">Advance repayments</span>
          <span class="text-sm font-semibold text-gray-900"><%= gbp(@monthly_summary[:advance_repayments]) %></span>
        </div>
        <div class="h-px bg-gray-100"></div>
        <div class="flex items-center justify-between">
          <span class="text-sm font-medium text-gray-700">Total deductions</span>
          <span class="text-sm font-bold text-primary-600">
            <%= gbp(@monthly_summary[:savings_total] + @monthly_summary[:advance_repayments]) %>
          </span>
        </div>
      </div>
    </div>
  </div>

</div>
