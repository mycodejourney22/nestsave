<%# Admin — Add Emergency Contact %>

<div class="max-w-lg">
  <div class="flex items-center gap-2 text-sm text-gray-400 mb-7">
    <%= link_to @profile.user.full_name,
          admin_employee_profile_path(@current_company.slug, @profile),
          class: "hover:text-gray-600 transition-colors" %>
    <span>/</span>
    <span class="text-gray-700 font-medium">Add emergency contact</span>
  </div>

  <h1 class="text-2xl font-semibold text-gray-900 mb-8">Add Emergency Contact</h1>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <%= form_with model: @contact,
          url: admin_employee_profile_emergency_contacts_path(@current_company.slug, @profile),
          method: :post do |f| %>

      <% if @contact.errors.any? %>
        <div class="mb-5 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
          <ul class="list-disc list-inside space-y-0.5">
            <% @contact.errors.full_messages.each do |msg| %>
              <li class="text-sm text-red-600"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <%= f.label :full_name, "Full name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :full_name, placeholder: "Jane Doe",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :relationship, "Relationship", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :relationship, placeholder: "e.g. Spouse, Parent, Sibling",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :phone, "Phone number", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.telephone_field :phone, placeholder: "+44 7700 900000",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :email, "Email (optional)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.email_field :email, placeholder: "jane@example.com",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <label class="flex items-center gap-3 cursor-pointer">
          <%= f.check_box :primary, class: "w-4 h-4 rounded border-gray-300 text-primary-500 focus:ring-primary-500" %>
          <span class="text-sm text-gray-700">Set as primary emergency contact</span>
        </label>
      </div>

      <div class="flex items-center gap-3 mt-6">
        <%= f.submit "Add contact",
              class: "bg-primary-500 hover:bg-primary-600 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors cursor-pointer" %>
        <%= link_to "Cancel",
              admin_employee_profile_path(@current_company.slug, @profile),
              class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors px-2 py-2" %>
      </div>
    <% end %>
  </div>
</div>
