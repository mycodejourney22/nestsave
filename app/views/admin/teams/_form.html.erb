<div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
  <%= form_with model: [@current_company, team],
        url: team.new_record? ? admin_teams_path(@current_company.slug) : admin_team_path(@current_company.slug, team) do |f| %>

    <% if team.errors.any? %>
      <div class="mb-5 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
        <ul class="list-disc list-inside space-y-0.5">
          <% team.errors.full_messages.each do |msg| %>
            <li class="text-sm text-red-600"><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-5">
      <div>
        <%= f.label :name, "Team name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :name, placeholder: "e.g. Engineering",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
      </div>
      <div>
        <%= f.label :description, "Description (optional)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_area :description, rows: 3, placeholder: "Brief description of this team's focus",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
      </div>
      <div class="flex items-center gap-3">
        <%= f.check_box :active, class: "h-4 w-4 rounded border-gray-300 text-primary-500 focus:ring-primary-500" %>
        <%= f.label :active, "Active", class: "text-sm font-medium text-gray-700" %>
      </div>
    </div>

    <div class="flex items-center gap-3 mt-6">
      <%= f.submit team.new_record? ? "Create team" : "Save changes",
            class: "bg-primary-500 hover:bg-primary-600 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors cursor-pointer" %>
      <%= link_to "Cancel", admin_teams_path(@current_company.slug),
            class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors px-2 py-2" %>
    </div>
  <% end %>
</div>
