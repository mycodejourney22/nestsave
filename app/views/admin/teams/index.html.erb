<%# Admin — Teams %>

<div class="flex items-center justify-between mb-7">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Teams</h1>
    <p class="text-gray-500 text-sm mt-1">Manage your company's teams</p>
  </div>
  <%= link_to new_admin_team_path(@current_company.slug),
        class: "inline-flex items-center gap-1.5 bg-primary-500 hover:bg-primary-600 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
    Add team
  <% end %>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <% if @teams.empty? %>
    <div class="flex flex-col items-center justify-center py-20 text-center px-8">
      <p class="text-sm font-medium text-gray-700">No teams yet</p>
      <p class="text-xs text-gray-400 mt-1">Create your first team to start organising employees</p>
    </div>
  <% else %>
    <table class="min-w-full">
      <thead>
        <tr class="bg-gray-50/70 border-b border-gray-100">
          <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Team</th>
          <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden sm:table-cell">Members</th>
          <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden md:table-cell">Manager</th>
          <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Status</th>
          <th class="text-right px-5 py-3.5"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @teams.each do |team| %>
          <tr class="hover:bg-gray-50/60 transition-colors">
            <td class="px-5 py-4">
              <%= link_to admin_team_path(@current_company.slug, team), class: "group" do %>
                <p class="text-sm font-semibold text-gray-900 group-hover:text-primary-600 transition-colors"><%= team.name %></p>
                <% if team.description.present? %>
                  <p class="text-xs text-gray-400 mt-0.5 truncate max-w-xs"><%= team.description %></p>
                <% end %>
              <% end %>
            </td>
            <td class="px-5 py-4 text-sm text-gray-600 hidden sm:table-cell">
              <%= link_to admin_team_path(@current_company.slug, team),
                    class: "hover:text-primary-600 transition-colors" do %>
                <%= team.employee_profiles.count %> member<%= team.employee_profiles.count == 1 ? "" : "s" %>
              <% end %>
            </td>
            <td class="px-5 py-4 text-sm text-gray-600 hidden md:table-cell">
              <%= team.manager&.full_name || "—" %>
            </td>
            <td class="px-5 py-4">
              <% if team.active? %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-600/20">Active</span>
              <% else %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-600 ring-1 ring-inset ring-gray-500/20">Inactive</span>
              <% end %>
            </td>
            <td class="px-5 py-4 text-right">
              <div class="flex items-center justify-end gap-3">
                <%= link_to "Edit", edit_admin_team_path(@current_company.slug, team),
                      class: "text-xs font-medium text-gray-500 hover:text-gray-700" %>
                <%= button_to "Delete", admin_team_path(@current_company.slug, team),
                      method: :delete,
                      data: { turbo_confirm: "Delete #{team.name}? This cannot be undone." },
                      class: "text-xs font-medium text-red-500 hover:text-red-700" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
