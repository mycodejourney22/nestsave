<%# Admin — Departments %>

<div class="flex items-center justify-between mb-7">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Departments</h1>
    <p class="text-gray-500 text-sm mt-1">Organise employees by department</p>
  </div>
  <%= link_to new_admin_department_path(@current_company.slug),
        class: "inline-flex items-center gap-1.5 bg-primary-500 hover:bg-primary-600 text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition-colors shadow-sm" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
    Add department
  <% end %>
</div>

<% if @departments.empty? %>
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm flex flex-col items-center justify-center py-20 text-center px-8">
    <div class="w-14 h-14 rounded-2xl bg-primary-50 flex items-center justify-center mb-4">
      <svg class="w-7 h-7 text-primary-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>
    </div>
    <p class="text-base font-semibold text-gray-900 mb-1">No departments yet</p>
    <p class="text-sm text-gray-400 mb-6 max-w-xs">Create departments to organise your team and filter employees.</p>
    <%= link_to "Create first department", new_admin_department_path(@current_company.slug),
          class: "inline-flex items-center gap-1.5 bg-primary-500 hover:bg-primary-600 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition-colors" %>
  </div>
<% else %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <table class="min-w-full">
      <thead>
        <tr class="bg-gray-50/70 border-b border-gray-100">
          <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Department</th>
          <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden sm:table-cell">Employees</th>
          <th class="text-right px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @departments.each do |dept| %>
          <tr class="hover:bg-gray-50/60 transition-colors">
            <td class="px-5 py-4">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 rounded-full flex-shrink-0" style="background-color: <%= dept.color %>"></div>
                <span class="text-sm font-medium text-gray-900"><%= dept.name %></span>
              </div>
            </td>
            <td class="px-5 py-4 text-sm text-gray-500 hidden sm:table-cell">
              <%= dept.employee_profiles.count %> employees
            </td>
            <td class="px-5 py-4 text-right">
              <div class="flex items-center gap-2 justify-end">
                <%= link_to "Edit",
                      edit_admin_department_path(@current_company.slug, dept),
                      class: "text-xs font-semibold text-primary-600 hover:text-primary-800 bg-primary-50 hover:bg-primary-100 px-3 py-1.5 rounded-lg transition-colors" %>
                <%= button_to "Remove",
                      admin_department_path(@current_company.slug, dept),
                      method: :delete,
                      data:   { turbo_confirm: "Remove the #{dept.name} department?" },
                      class:  "text-xs font-medium text-red-600 hover:text-red-800 bg-red-50 hover:bg-red-100 px-2.5 py-1.5 rounded-lg transition-colors border-0 cursor-pointer" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
