<%# Admin — Edit Employment History %>

<div class="max-w-lg">
  <div class="flex items-center gap-2 text-sm text-gray-400 mb-7">
    <%= link_to @profile.user.full_name,
          admin_employee_profile_path(@current_company.slug, @profile, tab: "work_history"),
          class: "hover:text-gray-600 transition-colors" %>
    <span>/</span>
    <span class="text-gray-700 font-medium">Edit employment history</span>
  </div>

  <h1 class="text-2xl font-semibold text-gray-900 mb-8">Edit Employment History</h1>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <%= form_with model: @history,
          url: admin_employee_profile_employment_history_path(@current_company.slug, @profile, @history),
          method: :patch do |f| %>

      <% if @history.errors.any? %>
        <div class="mb-5 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
          <ul class="list-disc list-inside space-y-0.5">
            <% @history.errors.full_messages.each do |msg| %>
              <li class="text-sm text-red-600"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <%= f.label :company_name, "Company name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :company_name,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :job_title, "Job title", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :job_title,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :start_date, "Start date", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.date_field :start_date,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          </div>
          <div>
            <%= f.label :end_date, "End date (optional)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.date_field :end_date,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          </div>
        </div>
        <p class="text-xs text-gray-400 -mt-2">
          Leave end date blank if this was their most recent role before joining <%= @current_company.name %>.
        </p>
        <div>
          <%= f.label :location, "Location (optional)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :location,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :reason_for_leaving, "Reason for leaving (optional)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :reason_for_leaving,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :notes, "Notes (optional)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_area :notes, rows: 3,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition resize-none" %>
        </div>
      </div>

      <div class="flex items-center gap-3 mt-6">
        <%= f.submit "Save changes",
              class: "bg-primary-500 hover:bg-primary-600 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors cursor-pointer" %>
        <%= link_to "Cancel",
              admin_employee_profile_path(@current_company.slug, @profile, tab: "work_history"),
              class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors px-2 py-2" %>
      </div>
    <% end %>
  </div>
</div>
