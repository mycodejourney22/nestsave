<%# Admin — Add Document %>

<div class="max-w-lg">
  <div class="flex items-center gap-2 text-sm text-gray-400 mb-7">
    <%= link_to "Employees", admin_employee_profiles_path(@current_company.slug),
          class: "hover:text-gray-600 transition-colors" %>
    <span>/</span>
    <%= link_to @profile.company_membership.display_name,
          admin_employee_profile_path(@current_company.slug, @profile, tab: "documents"),
          class: "hover:text-gray-600 transition-colors" %>
    <span>/</span>
    <span class="text-gray-700 font-medium">Add document</span>
  </div>

  <h1 class="text-2xl font-semibold text-gray-900 mb-8">Add Document</h1>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <%= form_with model: @document,
          url: admin_employee_profile_documents_path(@current_company.slug, @profile),
          method: :post do |f| %>

      <% if @document.errors.any? %>
        <div class="mb-5 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
          <ul class="list-disc list-inside space-y-0.5">
            <% @document.errors.full_messages.each do |msg| %>
              <li class="text-sm text-red-600"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-5">
        <div>
          <%= f.label :title, "Document title", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :title, placeholder: "e.g. Employment contract",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>

        <div>
          <%= f.label :category, "Category", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.select :category,
                [
                  ["Contract", "contract"],
                  ["Right to work", "right_to_work"],
                  ["Correspondence", "correspondence"],
                  ["Agreement", "agreement"],
                  ["Other", "other"]
                ],
                { include_blank: "Select category…" },
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition bg-white" %>
        </div>

        <div>
          <%= f.label :file, "File", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.file_field :file,
                accept: ".pdf,.doc,.docx,.png,.jpg,.jpeg",
                class: "block w-full text-sm text-gray-700 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer" %>
          <p class="text-xs text-gray-400 mt-1">PDF, Word, or image files. Max 10MB.</p>
        </div>

        <div>
          <%= f.label :notes, "Notes (optional)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_area :notes, rows: 3,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition resize-none" %>
        </div>
      </div>

      <div class="flex items-center gap-3 mt-6">
        <%= f.submit "Upload document",
              class: "bg-primary-500 hover:bg-primary-600 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors cursor-pointer" %>
        <%= link_to "Cancel",
              admin_employee_profile_path(@current_company.slug, @profile, tab: "documents"),
              class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors px-2 py-2" %>
      </div>
    <% end %>
  </div>
</div>
