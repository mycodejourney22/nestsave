<%# Admin — Update Bank Details %>

<div class="max-w-lg">
  <div class="flex items-center gap-2 text-sm text-gray-400 mb-7">
    <%= link_to "Employees", admin_employee_profiles_path(@current_company.slug),
          class: "hover:text-gray-600 transition-colors" %>
    <span>/</span>
    <%= link_to @profile.user.full_name,
          admin_employee_profile_path(@current_company.slug, @profile, tab: "bank_details"),
          class: "hover:text-gray-600 transition-colors" %>
    <span>/</span>
    <span class="text-gray-700 font-medium">Update bank details</span>
  </div>

  <h1 class="text-2xl font-semibold text-gray-900 mb-2">Update Bank Details</h1>
  <p class="text-sm text-gray-500 mb-8">
    A new record will be created and the current details deactivated. This action is permanent.
  </p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <%= form_with model: @bank_detail,
          url: admin_employee_profile_bank_details_path(@current_company.slug, @profile),
          method: :post do |f| %>

      <% if @bank_detail.errors.any? %>
        <div class="mb-5 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
          <ul class="list-disc list-inside space-y-0.5">
            <% @bank_detail.errors.full_messages.each do |msg| %>
              <li class="text-sm text-red-600"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-5">
        <div>
          <%= f.label :bank_name, "Bank name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :bank_name, placeholder: "e.g. Barclays",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div>
          <%= f.label :account_name, "Account name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :account_name, placeholder: "Full name as on account",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :sort_code, "Sort code", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.text_field :sort_code, placeholder: "00-00-00",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm font-mono focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          </div>
          <div>
            <%= f.label :account_number, "Account number", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.text_field :account_number, placeholder: "12345678",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm font-mono focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 mt-6">
        <%= f.submit "Save bank details",
              class: "bg-primary-500 hover:bg-primary-600 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors cursor-pointer" %>
        <%= link_to "Cancel",
              admin_employee_profile_path(@current_company.slug, @profile, tab: "bank_details"),
              class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors px-2 py-2" %>
      </div>
    <% end %>
  </div>
</div>
