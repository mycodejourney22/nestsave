<%# Admin — New Rota %>

<div class="max-w-lg">
  <div class="flex items-center gap-2 text-sm text-gray-400 mb-7">
    <%= link_to "Rotas", admin_rotas_path(@current_company.slug), class: "hover:text-gray-600 transition-colors" %>
    <span>/</span>
    <span class="text-gray-700 font-medium">New rota</span>
  </div>
  <h1 class="text-2xl font-semibold text-gray-900 mb-8">New Rota</h1>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <%= form_with model: [@current_company, @rota],
          url: admin_rotas_path(@current_company.slug) do |f| %>

      <% if @rota.errors.any? %>
        <div class="mb-5 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
          <ul class="list-disc list-inside space-y-0.5">
            <% @rota.errors.full_messages.each do |msg| %>
              <li class="text-sm text-red-600"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-5">
        <div>
          <%= f.label :team_id, "Team", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.select :team_id,
                @teams.map { |t| [t.name, t.id] },
                { selected: @team&.id },
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>

        <div>
          <%= f.label :week_start, "Week starting (Monday)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.date_field :week_start, value: @week_start,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          <p class="text-xs text-gray-400 mt-1">Select any Monday — the rota covers Mon–Sun</p>
        </div>
      </div>

      <div class="flex items-center gap-3 mt-6">
        <%= f.submit "Create rota",
              class: "bg-primary-500 hover:bg-primary-600 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors cursor-pointer" %>
        <%= link_to "Cancel", admin_rotas_path(@current_company.slug),
              class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors px-2 py-2" %>
      </div>
    <% end %>
  </div>
</div>
