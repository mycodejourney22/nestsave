<%# Admin — Leave Requests %>

<div class="flex items-center justify-between mb-7">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Leave Requests</h1>
    <p class="text-gray-500 text-sm mt-1">Review and manage employee leave</p>
  </div>
</div>

<% if notice.present? %>
  <div class="mb-5 rounded-xl bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-700"><%= notice %></div>
<% end %>
<% if alert.present? %>
  <div class="mb-5 rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700"><%= alert %></div>
<% end %>

<%# Pending requests %>
<div class="mb-8">
  <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">
    Pending
    <% if @pending_requests.any? %>
      <span class="ml-1.5 inline-flex items-center justify-center w-5 h-5 rounded-full bg-amber-100 text-amber-700 text-xs font-bold"><%= @pending_requests.size %></span>
    <% end %>
  </h2>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <% if @pending_requests.empty? %>
      <div class="flex flex-col items-center justify-center py-14 text-center px-8">
        <p class="text-sm font-medium text-gray-700">No pending requests</p>
        <p class="text-xs text-gray-400 mt-1">New requests will appear here</p>
      </div>
    <% else %>
      <table class="min-w-full">
        <thead>
          <tr class="bg-gray-50/70 border-b border-gray-100">
            <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Employee</th>
            <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden sm:table-cell">Leave type</th>
            <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden md:table-cell">Dates</th>
            <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden md:table-cell">Days</th>
            <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden lg:table-cell">Reason</th>
            <th class="text-right px-5 py-3.5"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @pending_requests.each do |req| %>
            <tr class="hover:bg-gray-50/60 transition-colors">
              <td class="px-5 py-4">
                <p class="text-sm font-medium text-gray-900"><%= req.employee_profile.full_name %></p>
                <% if req.employee_profile.team.present? %>
                  <p class="text-xs text-gray-400 mt-0.5"><%= req.employee_profile.team.name %></p>
                <% end %>
              </td>
              <td class="px-5 py-4 hidden sm:table-cell">
                <% cat_colors = { "annual" => "bg-blue-50 text-blue-700 ring-blue-600/20", "sick" => "bg-amber-50 text-amber-700 ring-amber-600/20", "maternity" => "bg-pink-50 text-pink-700 ring-pink-600/20", "other" => "bg-gray-100 text-gray-600 ring-gray-500/20" } %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ring-1 ring-inset <%= cat_colors.fetch(req.leave_type.category, cat_colors["other"]) %>">
                  <%= req.leave_type.name %>
                </span>
              </td>
              <td class="px-5 py-4 text-sm text-gray-600 hidden md:table-cell">
                <%= req.start_date.strftime("%-d %b") %> – <%= req.end_date.strftime("%-d %b %Y") %>
              </td>
              <td class="px-5 py-4 text-sm text-gray-600 hidden md:table-cell">
                <%= req.total_days %> day<%= req.total_days == 1 ? "" : "s" %>
              </td>
              <td class="px-5 py-4 text-sm text-gray-500 hidden lg:table-cell max-w-xs truncate">
                <%= req.reason.presence || "—" %>
              </td>
              <td class="px-5 py-4 text-right">
                <div class="flex items-center justify-end gap-2">
                  <%= button_to "Approve",
                        approve_admin_leave_request_path(@current_company.slug, req),
                        method: :patch,
                        class: "text-xs font-semibold px-3 py-1.5 rounded-lg bg-emerald-500 hover:bg-emerald-600 text-white transition-colors" %>
                  <%= button_to "Decline",
                        decline_admin_leave_request_path(@current_company.slug, req),
                        method: :patch,
                        data: { turbo_confirm: "Decline this leave request?" },
                        class: "text-xs font-semibold px-3 py-1.5 rounded-lg bg-white border border-gray-300 text-gray-600 hover:bg-gray-50 transition-colors" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>

<%# Recent requests %>
<div>
  <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Recent</h2>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <% if @recent_requests.empty? %>
      <div class="flex flex-col items-center justify-center py-14 text-center px-8">
        <p class="text-sm font-medium text-gray-700">No reviewed requests yet</p>
      </div>
    <% else %>
      <table class="min-w-full">
        <thead>
          <tr class="bg-gray-50/70 border-b border-gray-100">
            <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Employee</th>
            <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden sm:table-cell">Leave type</th>
            <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden md:table-cell">Dates</th>
            <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden md:table-cell">Days</th>
            <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @recent_requests.each do |req| %>
            <tr class="hover:bg-gray-50/60 transition-colors">
              <td class="px-5 py-4">
                <p class="text-sm font-medium text-gray-900"><%= req.employee_profile.full_name %></p>
              </td>
              <td class="px-5 py-4 text-sm text-gray-600 hidden sm:table-cell"><%= req.leave_type.name %></td>
              <td class="px-5 py-4 text-sm text-gray-600 hidden md:table-cell">
                <%= req.start_date.strftime("%-d %b") %> – <%= req.end_date.strftime("%-d %b %Y") %>
              </td>
              <td class="px-5 py-4 text-sm text-gray-600 hidden md:table-cell">
                <%= req.total_days %> day<%= req.total_days == 1 ? "" : "s" %>
              </td>
              <td class="px-5 py-4">
                <% status_colors = { "approved" => "bg-emerald-50 text-emerald-700 ring-emerald-600/20", "declined" => "bg-red-50 text-red-700 ring-red-600/20", "cancelled" => "bg-gray-100 text-gray-500 ring-gray-500/20" } %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ring-1 ring-inset <%= status_colors.fetch(req.status, "bg-gray-100 text-gray-500 ring-gray-500/20") %>">
                  <%= req.status.capitalize %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
