<h1 style="margin:0 0 8px;font-family:Georgia,'Times New Roman',serif;font-size:22px;
            font-weight:bold;color:#111827;line-height:1.2;">
  Monthly saving confirmed
</h1>
<p style="margin:0 0 20px;font-family:Arial,Helvetica,sans-serif;font-size:15px;
           color:#374151;line-height:1.6;">
  Hi <%= @user.full_name.split.first %>, your monthly saving was deducted from your salary this payroll cycle.
</p>

<!-- Amount highlight -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="background-color:#f3faf7;border-radius:8px;margin:0 0 20px;">
  <tr>
    <td style="padding:20px 24px;text-align:center;">
      <p style="margin:0 0 4px;font-family:Arial,Helvetica,sans-serif;font-size:13px;
                 color:#1D9E75;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;">
        This month's saving
      </p>
      <p style="margin:0;font-family:Georgia,'Times New Roman',serif;font-size:36px;
                 font-weight:bold;color:#1D9E75;">
        <%= formatted_currency(@plan.monthly_amount) %>
      </p>
      <p style="margin:4px 0 0;font-family:Arial,Helvetica,sans-serif;font-size:13px;
                 color:#6b7280;"><%= @plan.name %></p>
    </td>
  </tr>
</table>

<!-- Running total + progress -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="border:1px solid #e5e7eb;border-radius:6px;margin:0 0 8px;">
  <tr>
    <td style="padding:14px 18px;border-bottom:1px solid #f3f4f6;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;">
            Running total
          </td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;
                     color:#111827;text-align:right;">
            <%= formatted_currency(@plan.total_saved) %>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding:14px 18px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;">
            Target
          </td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                     color:#111827;text-align:right;">
            <%= formatted_currency(@plan.target_amount) %>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<!-- Progress bar -->
<% pct = [@plan.progress_percentage.to_i, 100].min %>
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="margin:0 0 4px;">
  <tr>
    <td style="background-color:#e5e7eb;border-radius:4px;height:10px;" height="10">
      <table width="<%= pct %>%" cellpadding="0" cellspacing="0" border="0" role="presentation">
        <tr>
          <td style="background-color:#1D9E75;border-radius:4px;line-height:10px;
                     font-size:1px;" height="10">&nbsp;</td>
        </tr>
      </table>
    </td>
  </tr>
</table>
<p style="margin:4px 0 24px;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#9ca3af;">
  <%= pct %>% of target reached
  <% remaining_months = @plan.duration_months - ((@plan.total_saved / @plan.monthly_amount).to_i rescue 0) %>
  &bull; approx. <%= [remaining_months, 0].max %> months remaining
</p>

<!-- CTA -->
<table cellpadding="0" cellspacing="0" border="0" role="presentation">
  <tr>
    <td style="border-radius:6px;background-color:#1D9E75;" class="btn-td">
      <a href="<%= @plan_url %>"
         style="display:inline-block;padding:12px 24px;font-family:Arial,Helvetica,sans-serif;
                font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;
                border-radius:6px;line-height:1.2;">
        View your savings &rarr;
      </a>
    </td>
  </tr>
</table>
