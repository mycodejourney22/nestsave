<!-- Header band -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="background-color:#f0fdf4;border:1px solid #86efac;border-radius:6px;margin:0 0 24px;">
  <tr>
    <td style="padding:12px 16px;">
      <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;color:#166534;">
        &#10003; Your payslip is ready
      </p>
    </td>
  </tr>
</table>

<h1 style="margin:0 0 8px;font-family:Georgia,'Times New Roman',serif;font-size:22px;font-weight:bold;color:#111827;line-height:1.2;">
  <%= @run.period_label %> payslip
</h1>
<p style="margin:0 0 24px;font-family:Arial,Helvetica,sans-serif;font-size:15px;color:#374151;line-height:1.6;">
  Hi <%= @user.full_name.split.first %>, your payslip for <strong><%= @run.period_label %></strong> has been processed and is now available to view.
</p>

<!-- Net pay highlight -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="background-color:#0f1a14;border-radius:8px;margin:0 0 24px;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 4px;font-family:Arial,Helvetica,sans-serif;font-size:12px;font-weight:700;
                 color:#6ee7b7;letter-spacing:0.5px;text-transform:uppercase;">Net pay</p>
      <p style="margin:0;font-family:Georgia,'Times New Roman',serif;font-size:32px;font-weight:bold;color:#ffffff;">
        <%= formatted_currency(@entry.net_pay) %>
      </p>
      <p style="margin:4px 0 0;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#6b7280;">
        <%= @run.period_label %> &bull; <%= @user.full_name %>
      </p>
    </td>
  </tr>
</table>

<!-- Earnings summary -->
<p style="margin:0 0 8px;font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;
           color:#9ca3af;letter-spacing:0.5px;text-transform:uppercase;">Earnings</p>
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="border:1px solid #e5e7eb;border-radius:6px;overflow:hidden;margin:0 0 16px;">
  <% @entry.earnings_items.each_with_index do |item, i| %>
    <tr style="<%= i.even? ? 'background-color:#ffffff;' : 'background-color:#fafafa;' %>">
      <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#374151;
                 padding:9px 14px;border-bottom:1px solid #f3f4f6;">
        <%= item.label %>
      </td>
      <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                 color:#111827;padding:9px 14px;border-bottom:1px solid #f3f4f6;text-align:right;">
        <%= formatted_currency(item.amount) %>
      </td>
    </tr>
  <% end %>
  <tr style="background-color:#f3faf7;">
    <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:700;
               color:#166534;padding:10px 14px;">Total earnings</td>
    <td style="font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;
               color:#1D9E75;padding:10px 14px;text-align:right;">
      <%= formatted_currency(@entry.total_earnings) %>
    </td>
  </tr>
</table>

<!-- Deductions summary -->
<p style="margin:0 0 8px;font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;
           color:#9ca3af;letter-spacing:0.5px;text-transform:uppercase;">Deductions</p>
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="border:1px solid #e5e7eb;border-radius:6px;overflow:hidden;margin:0 0 24px;">
  <% @entry.deductions_items.each_with_index do |item, i| %>
    <tr style="<%= i.even? ? 'background-color:#ffffff;' : 'background-color:#fafafa;' %>">
      <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#374151;
                 padding:9px 14px;border-bottom:1px solid #f3f4f6;">
        <%= item.label %>
      </td>
      <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                 color:#dc2626;padding:9px 14px;border-bottom:1px solid #f3f4f6;text-align:right;">
        -<%= formatted_currency(item.amount) %>
      </td>
    </tr>
  <% end %>
  <tr style="background-color:#fff7f7;">
    <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:700;
               color:#991b1b;padding:10px 14px;">Total deductions</td>
    <td style="font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;
               color:#dc2626;padding:10px 14px;text-align:right;">
      -<%= formatted_currency(@entry.total_deductions) %>
    </td>
  </tr>
</table>

<p style="margin:0 0 24px;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;line-height:1.5;">
  This is your official payslip for <%= @run.period_label %>. Please keep it for your records.
</p>

<!-- CTA -->
<table cellpadding="0" cellspacing="0" border="0" role="presentation">
  <tr>
    <td style="border-radius:6px;background-color:#1D9E75;" class="btn-td">
      <a href="<%= @url %>"
         style="display:inline-block;padding:12px 24px;font-family:Arial,Helvetica,sans-serif;
                font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:6px;line-height:1.2;">
        View full payslip &rarr;
      </a>
    </td>
  </tr>
</table>
