<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="background-color:#fef2f2;border:1px solid #fca5a5;border-radius:6px;margin:0 0 24px;">
  <tr>
    <td style="padding:12px 16px;">
      <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;color:#991b1b;">
        Leave request update
      </p>
    </td>
  </tr>
</table>

<h1 style="margin:0 0 8px;font-family:Georgia,'Times New Roman',serif;font-size:22px;font-weight:bold;color:#111827;line-height:1.2;">
  Your leave request was not approved
</h1>
<p style="margin:0 0 24px;font-family:Arial,Helvetica,sans-serif;font-size:15px;color:#374151;line-height:1.6;">
  Hi <%= @user.full_name.split.first %>, unfortunately your leave request for
  <strong><%= @request.start_date.strftime("%-d %b") %> – <%= @request.end_date.strftime("%-d %b %Y") %></strong>
  has not been approved at this time.
</p>

<% if @note.present? %>
  <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
         style="background-color:#fff7ed;border-left:3px solid #fb923c;border-radius:0 6px 6px 0;margin:0 0 24px;">
    <tr>
      <td style="padding:14px 18px;">
        <p style="margin:0 0 4px;font-family:Arial,Helvetica,sans-serif;font-size:12px;font-weight:700;color:#9a3412;text-transform:uppercase;letter-spacing:0.4px;">Note from your manager</p>
        <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#374151;line-height:1.5;"><%= @note %></p>
      </td>
    </tr>
  </table>
<% end %>

<p style="margin:0 0 24px;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#374151;line-height:1.5;">
  If you have questions, please speak to your HR admin or team manager. You can submit a new request at a different time.
</p>

<table cellpadding="0" cellspacing="0" border="0" role="presentation">
  <tr>
    <td style="border-radius:6px;background-color:#1D9E75;">
      <a href="<%= @url %>"
         style="display:inline-block;padding:12px 24px;font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:6px;line-height:1.2;">
        Request leave again &rarr;
      </a>
    </td>
  </tr>
</table>
