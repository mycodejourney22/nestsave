<!-- Confirmation banner -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="background-color:#f0fdf4;border:1px solid #86efac;border-radius:6px;margin:0 0 24px;">
  <tr>
    <td style="padding:12px 16px;">
      <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:14px;
                 font-weight:700;color:#166534;">
        &#10003; Funds sent
      </p>
    </td>
  </tr>
</table>

<h1 style="margin:0 0 8px;font-family:Georgia,'Times New Roman',serif;font-size:22px;
            font-weight:bold;color:#111827;line-height:1.2;">
  Your advance has been disbursed
</h1>
<p style="margin:0 0 24px;font-family:Arial,Helvetica,sans-serif;font-size:15px;
           color:#374151;line-height:1.6;">
  Hi <%= @user.full_name.split.first %>,
  <strong><%= formatted_currency(@advance.amount) %></strong>
  has been sent to you. Check your bank account — it may take 1–2 working days to arrive.
</p>

<!-- Summary -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="background-color:#f3faf7;border-left:3px solid #1D9E75;border-radius:0 6px 6px 0;
              margin:0 0 20px;">
  <tr>
    <td style="padding:16px 20px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                     padding-bottom:8px;width:40%;">Amount sent</td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:16px;font-weight:700;
                     color:#1D9E75;padding-bottom:8px;"><%= formatted_currency(@advance.amount) %></td>
        </tr>
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                     padding-bottom:8px;">Repayment period</td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                     color:#111827;padding-bottom:8px;"><%= @advance.repayment_months %> months</td>
        </tr>
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                     padding-bottom:8px;">Monthly instalment</td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                     color:#111827;padding-bottom:8px;"><%= formatted_currency(@advance.monthly_instalment) %></td>
        </tr>
        <% if @schedules.first %>
          <tr>
            <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;">
              First repayment
            </td>
            <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                       color:#111827;">
              <%= formatted_date(@schedules.first.due_date) %>
            </td>
          </tr>
        <% end %>
      </table>
    </td>
  </tr>
</table>

<p style="margin:0 0 16px;font-family:Arial,Helvetica,sans-serif;font-size:14px;
           color:#374151;line-height:1.5;">
  Repayments will be deducted automatically from your salary each payroll cycle.
</p>

<!-- Repayment schedule table -->
<% if @schedules.any? %>
  <p style="margin:0 0 8px;font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:700;
             color:#374151;letter-spacing:0.3px;text-transform:uppercase;">
    Repayment schedule
  </p>
  <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
         style="border:1px solid #e5e7eb;border-radius:6px;overflow:hidden;margin:0 0 28px;">
    <tr style="background-color:#f9fafb;">
      <td style="font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;
                 color:#9ca3af;padding:8px 14px;border-bottom:1px solid #e5e7eb;
                 letter-spacing:0.5px;text-transform:uppercase;">#</td>
      <td style="font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;
                 color:#9ca3af;padding:8px 14px;border-bottom:1px solid #e5e7eb;
                 letter-spacing:0.5px;text-transform:uppercase;text-align:right;">Amount</td>
      <td style="font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;
                 color:#9ca3af;padding:8px 14px;border-bottom:1px solid #e5e7eb;
                 letter-spacing:0.5px;text-transform:uppercase;text-align:right;">Due date</td>
    </tr>
    <% @schedules.each_with_index do |s, i| %>
      <tr style="<%= i.even? ? 'background-color:#ffffff;' : 'background-color:#fafafa;' %>">
        <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#374151;
                   padding:9px 14px;border-bottom:1px solid #f3f4f6;">
          <%= s.instalment_number %>
        </td>
        <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                   color:#111827;padding:9px 14px;border-bottom:1px solid #f3f4f6;text-align:right;">
          <%= formatted_currency(s.amount) %>
        </td>
        <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                   padding:9px 14px;border-bottom:1px solid #f3f4f6;text-align:right;
                   white-space:nowrap;">
          <%= formatted_date(s.due_date) %>
        </td>
      </tr>
    <% end %>
  </table>
<% else %>
  <p style="margin:0 0 28px;"></p>
<% end %>

<!-- CTA -->
<table cellpadding="0" cellspacing="0" border="0" role="presentation">
  <tr>
    <td style="border-radius:6px;background-color:#1D9E75;" class="btn-td">
      <a href="<%= @advance_url %>"
         style="display:inline-block;padding:12px 24px;font-family:Arial,Helvetica,sans-serif;
                font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;
                border-radius:6px;line-height:1.2;">
        View advance details &rarr;
      </a>
    </td>
  </tr>
</table>
