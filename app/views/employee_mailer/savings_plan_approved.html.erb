<!-- Success banner -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="background-color:#f0fdf4;border:1px solid #86efac;border-radius:6px;margin:0 0 24px;">
  <tr>
    <td style="padding:12px 16px;">
      <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:14px;
                 font-weight:700;color:#166534;">
        &#10003; Plan approved
      </p>
    </td>
  </tr>
</table>

<h1 style="margin:0 0 8px;font-family:Georgia,'Times New Roman',serif;font-size:22px;
            font-weight:bold;color:#111827;line-height:1.2;">
  Your savings plan is now active
</h1>
<p style="margin:0 0 24px;font-family:Arial,Helvetica,sans-serif;font-size:15px;
           color:#374151;line-height:1.6;">
  Great news, <%= @user.full_name.split.first %>! Your savings plan "<strong><%= @plan.name %></strong>"
  has been approved and is now active.
</p>

<!-- Plan details -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="background-color:#f3faf7;border-left:3px solid #1D9E75;border-radius:0 6px 6px 0;
              margin:0 0 20px;">
  <tr>
    <td style="padding:16px 20px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                     padding-bottom:8px;width:40%;">Plan name</td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                     color:#111827;padding-bottom:8px;"><%= @plan.name %></td>
        </tr>
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                     padding-bottom:8px;">Monthly saving</td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;
                     color:#1D9E75;padding-bottom:8px;"><%= formatted_currency(@plan.monthly_amount) %></td>
        </tr>
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                     padding-bottom:8px;">Target amount</td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                     color:#111827;padding-bottom:8px;"><%= formatted_currency(@plan.target_amount) %></td>
        </tr>
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;">Maturity date</td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                     color:#111827;"><%= formatted_date(@plan.maturity_date) %></td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<p style="margin:0 0 8px;font-family:Arial,Helvetica,sans-serif;font-size:14px;
           color:#374151;line-height:1.5;">
  Your first deduction of <strong><%= formatted_currency(@plan.monthly_amount) %></strong>
  will be on <strong><%= formatted_date(@plan.start_date) %></strong>.
</p>

<!-- Progress bar (starting at 0%) -->
<p style="margin:16px 0 6px;font-family:Arial,Helvetica,sans-serif;font-size:12px;
           color:#9ca3af;">Progress</p>
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="margin:0 0 4px;">
  <tr>
    <td style="background-color:#e5e7eb;border-radius:4px;height:8px;" height="8">
      <table width="1%" cellpadding="0" cellspacing="0" border="0" role="presentation">
        <tr>
          <td style="background-color:#1D9E75;border-radius:4px;line-height:8px;
                     font-size:1px;" height="8">&nbsp;</td>
        </tr>
      </table>
    </td>
  </tr>
</table>
<p style="margin:0 0 28px;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#9ca3af;">
  <%= formatted_currency(0) %> of <%= formatted_currency(@plan.target_amount) %>
</p>

<!-- CTA -->
<table cellpadding="0" cellspacing="0" border="0" role="presentation">
  <tr>
    <td style="border-radius:6px;background-color:#1D9E75;" class="btn-td">
      <a href="<%= @plan_url %>"
         style="display:inline-block;padding:12px 24px;font-family:Arial,Helvetica,sans-serif;
                font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;
                border-radius:6px;line-height:1.2;">
        View your plan &rarr;
      </a>
    </td>
  </tr>
</table>
