<%# Employee — Notifications %>

<div class="flex items-center justify-between mb-7">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Notifications</h1>
    <p class="text-gray-500 text-sm mt-1">All your recent activity</p>
  </div>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <% if @notifications.empty? %>
    <div class="flex flex-col items-center justify-center py-16 text-center px-8">
      <div class="w-12 h-12 rounded-2xl bg-gray-100 flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>
        </svg>
      </div>
      <p class="text-sm font-medium text-gray-700 mb-1">You're all caught up ✓</p>
      <p class="text-xs text-gray-400">New notifications will appear here.</p>
    </div>
  <% else %>
    <ul class="divide-y divide-gray-100">
      <% @notifications.each do |n| %>
        <li class="<%= n.read? ? "" : "bg-primary-50/40 border-l-2 border-primary-500" %>">
          <%= link_to (n.link.presence || "#"),
                class: "flex items-start gap-4 px-5 py-4 hover:bg-gray-50 transition-colors block" do %>
            <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5
                        <%= case n.category
                            when "leave"    then "bg-blue-100"
                            when "advance"  then "bg-purple-100"
                            when "savings"  then "bg-emerald-100"
                            when "payroll"  then "bg-teal-100"
                            else "bg-gray-100"
                            end %>">
              <svg class="w-4 h-4 <%= case n.category
                                      when "leave"   then "text-blue-600"
                                      when "advance" then "text-purple-600"
                                      when "savings" then "text-emerald-600"
                                      when "payroll" then "text-teal-600"
                                      else "text-gray-500"
                                      end %>"
                   fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-3">
                <p class="text-sm font-semibold text-gray-900"><%= n.title %></p>
                <% unless n.read? %>
                  <span class="w-2 h-2 rounded-full bg-primary-500 flex-shrink-0 mt-1.5"></span>
                <% end %>
              </div>
              <% if n.body.present? %>
                <p class="text-sm text-gray-500 mt-0.5"><%= n.body %></p>
              <% end %>
              <p class="text-xs text-gray-400 mt-1"><%= distance_of_time_in_words_to_now(n.created_at) %> ago</p>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
