<%# Employee — My Profile %>

<div class="flex items-center justify-between mb-7">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">My Profile</h1>
    <p class="text-gray-500 text-sm mt-1">Your employment details and records</p>
  </div>
</div>

<% unless @profile %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-10 text-center">
    <p class="text-sm text-gray-500">Your profile hasn't been set up yet. Contact HR for assistance.</p>
  </div>
<% else %>

<%# Tabs %>
<div class="border-b border-gray-200 mb-6">
  <nav class="-mb-px flex gap-6" id="profile-tabs">
    <a href="#overview"     class="profile-tab border-b-2 border-primary-500 text-primary-600 pb-3 text-sm font-medium cursor-pointer">Overview</a>
    <a href="#salary"       class="profile-tab border-b-2 border-transparent text-gray-500 hover:text-gray-700 pb-3 text-sm font-medium cursor-pointer">Salary history</a>
    <a href="#documents"    class="profile-tab border-b-2 border-transparent text-gray-500 hover:text-gray-700 pb-3 text-sm font-medium cursor-pointer">Documents</a>
    <a href="#bank"         class="profile-tab border-b-2 border-transparent text-gray-500 hover:text-gray-700 pb-3 text-sm font-medium cursor-pointer">Bank details</a>
    <a href="#work-history" class="profile-tab border-b-2 border-transparent text-gray-500 hover:text-gray-700 pb-3 text-sm font-medium cursor-pointer">Work history</a>
  </nav>
</div>

<%# ── Overview ─────────────────────────────────────────────────── %>
<div id="overview" class="tab-panel space-y-6">

  <%# Personal info %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-sm font-semibold text-gray-900">Personal information</h2>
    </div>
    <div class="px-6 py-5 grid sm:grid-cols-2 gap-x-8 gap-y-4">
      <div>
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Full name</p>
        <p class="text-sm text-gray-900"><%= current_user.full_name %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Email</p>
        <p class="text-sm text-gray-900"><%= current_user.email %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Employee number</p>
        <p class="text-sm text-gray-900"><%= @profile.employee_number %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Job title</p>
        <p class="text-sm text-gray-900"><%= @profile.job_title.presence || "—" %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Department</p>
        <p class="text-sm text-gray-900"><%= @profile.department&.name || "—" %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Employment type</p>
        <p class="text-sm text-gray-900"><%= @profile.employment_type_label %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Start date</p>
        <p class="text-sm text-gray-900"><%= @profile.employment_start_date&.strftime("%-d %b %Y") || "—" %></p>
      </div>
    </div>
  </div>

  <%# Emergency contacts %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-sm font-semibold text-gray-900">Emergency contacts</h2>
    </div>
    <% if @emergency_contacts.empty? %>
      <div class="px-6 py-8 text-center">
        <p class="text-sm text-gray-400">No emergency contacts on file</p>
      </div>
    <% else %>
      <ul class="divide-y divide-gray-100">
        <% @emergency_contacts.each do |ec| %>
          <li class="px-6 py-4 flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-gray-900"><%= ec.full_name %></p>
              <p class="text-xs text-gray-500 mt-0.5"><%= ec.relationship.humanize %> &middot; <%= ec.phone %></p>
              <% if ec.email.present? %>
                <p class="text-xs text-gray-400 mt-0.5"><%= ec.email %></p>
              <% end %>
            </div>
            <% if ec.primary? %>
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-primary-50 text-primary-700 ring-1 ring-inset ring-primary-600/20 flex-shrink-0">Primary</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>

</div>

<%# ── Salary history ───────────────────────────────────────────── %>
<div id="salary" class="tab-panel hidden">
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <% if @salary_history.empty? %>
      <div class="flex flex-col items-center justify-center py-16 text-center px-8">
        <p class="text-sm font-medium text-gray-700">No salary records</p>
        <p class="text-xs text-gray-400 mt-1">Your salary history will appear here once recorded by HR</p>
      </div>
    <% else %>
      <table class="min-w-full">
        <thead>
          <tr class="bg-gray-50/70 border-b border-gray-100">
            <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Effective date</th>
            <th class="text-right px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Monthly salary</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @salary_history.each_with_index do |sh, i| %>
            <tr class="hover:bg-gray-50/60 transition-colors">
              <td class="px-5 py-4 text-sm text-gray-700">
                <%= sh.effective_date.strftime("%-d %b %Y") %>
                <% if i == 0 %>
                  <span class="ml-2 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-600/20">Current</span>
                <% end %>
              </td>
              <td class="px-5 py-4 text-sm font-semibold text-right text-gray-900"><%= gbp(sh.amount) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>

<%# ── Documents ────────────────────────────────────────────────── %>
<div id="documents" class="tab-panel hidden">
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <% if @documents.empty? %>
      <div class="flex flex-col items-center justify-center py-16 text-center px-8">
        <p class="text-sm font-medium text-gray-700">No documents yet</p>
        <p class="text-xs text-gray-400 mt-1">Documents shared by HR will appear here</p>
      </div>
    <% else %>
      <ul class="divide-y divide-gray-100">
        <% @documents.each do |doc| %>
          <li class="flex items-center gap-4 px-5 py-4">
            <div class="w-9 h-9 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate"><%= doc.title %></p>
              <p class="text-xs text-gray-400 mt-0.5"><%= doc.category_label.capitalize %> &middot; <%= doc.file_size_display %> &middot; <%= doc.created_at.strftime("%-d %b %Y") %></p>
            </div>
            <% if doc.file_url %>
              <div class="flex items-center gap-2 flex-shrink-0">
                <%= link_to doc.file_url, target: "_blank", rel: "noopener",
                      class: "text-xs font-medium text-primary-600 hover:text-primary-700" do %>
                  View
                <% end %>
                <%= link_to doc.download_url, target: "_blank", rel: "noopener",
                      class: "text-xs font-medium text-gray-500 hover:text-gray-700" do %>
                  Download
                <% end %>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
</div>

<%# ── Bank details ─────────────────────────────────────────────── %>
<div id="bank" class="tab-panel hidden">
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <% if @bank_detail.nil? %>
      <div class="flex flex-col items-center justify-center py-16 text-center px-8">
        <p class="text-sm font-medium text-gray-700">No bank details on file</p>
        <p class="text-xs text-gray-400 mt-1">Contact HR to add your payment details</p>
      </div>
    <% else %>
      <div class="px-6 py-5 grid sm:grid-cols-2 gap-x-8 gap-y-4">
        <div>
          <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Bank name</p>
          <p class="text-sm text-gray-900"><%= @bank_detail.bank_name %></p>
        </div>
        <div>
          <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Account name</p>
          <p class="text-sm text-gray-900"><%= @bank_detail.account_name %></p>
        </div>
        <div>
          <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Account number</p>
          <p class="text-sm text-gray-900"><%= @bank_detail.account_number %></p>
        </div>
        <% if @bank_detail.sort_code.present? %>
          <div>
            <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Sort code</p>
            <p class="text-sm text-gray-900"><%= @bank_detail.sort_code %></p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# ── Work history ─────────────────────────────────────────────── %>
<div id="work-history" class="tab-panel hidden">
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <% if @employment_histories.empty? %>
      <div class="flex flex-col items-center justify-center py-16 text-center px-8">
        <p class="text-sm font-medium text-gray-700">No work history on file</p>
        <p class="text-xs text-gray-400 mt-1">Previous employment history added by HR will appear here</p>
      </div>
    <% else %>
      <ul class="divide-y divide-gray-100">
        <% @employment_histories.each do |eh| %>
          <li class="px-6 py-5">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-900"><%= eh.job_title %></p>
                <p class="text-sm text-gray-600 mt-0.5"><%= eh.company_name %></p>
                <% if eh.location.present? %>
                  <p class="text-xs text-gray-400 mt-0.5"><%= eh.location %></p>
                <% end %>
                <p class="text-xs text-gray-400 mt-1">
                  <%= eh.start_date.strftime("%b %Y") %> –
                  <%= eh.current? ? "Present" : eh.end_date.strftime("%b %Y") %>
                  &middot; <%= eh.duration %>
                </p>
                <% if eh.notes.present? %>
                  <p class="text-xs text-gray-500 mt-2"><%= eh.notes %></p>
                <% end %>
              </div>
              <% if eh.current? %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-600/20 flex-shrink-0">Current</span>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
</div>

<% end %>

<script>
  (function() {
    const tabs   = document.querySelectorAll('.profile-tab')
    const panels = document.querySelectorAll('.tab-panel')

    function activate(hash) {
      const target = hash.replace('#', '')
      tabs.forEach(t => {
        const active = t.getAttribute('href') === hash
        t.classList.toggle('border-primary-500', active)
        t.classList.toggle('text-primary-600', active)
        t.classList.toggle('border-transparent', !active)
        t.classList.toggle('text-gray-500', !active)
      })
      panels.forEach(p => p.classList.toggle('hidden', p.id !== target))
    }

    tabs.forEach(t => t.addEventListener('click', e => {
      e.preventDefault()
      history.replaceState(null, '', t.getAttribute('href'))
      activate(t.getAttribute('href'))
    }))

    activate(location.hash || '#overview')
  })()
</script>
