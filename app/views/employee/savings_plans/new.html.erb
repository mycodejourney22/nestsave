<%# Employee — New Savings Plan %>

<div class="max-w-lg">
  <%# Breadcrumb %>
  <div class="flex items-center gap-2 text-sm text-gray-400 mb-7">
    <%= link_to "Savings Plans", employee_savings_plans_path(@current_company.slug),
          class: "hover:text-gray-600 transition-colors" %>
    <span>/</span>
    <span class="text-gray-700 font-medium">New plan</span>
  </div>

  <h1 class="text-2xl font-semibold text-gray-900 mb-2">New Savings Plan</h1>
  <p class="text-sm text-gray-500 mb-8">
    Choose a monthly amount and duration. Your payroll manager will review and activate the plan.
    Deductions start from your next payroll date.
  </p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <%= form_with model: @plan,
          url: employee_savings_plans_path(@current_company.slug),
          method: :post do |f| %>

      <% if @plan.errors.any? %>
        <div class="mb-5 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
          <p class="text-sm font-semibold text-red-700 mb-1">Please fix the following:</p>
          <ul class="list-disc list-inside space-y-0.5">
            <% @plan.errors.full_messages.each do |msg| %>
              <li class="text-sm text-red-600"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-5">
        <div>
          <%= f.label :name, "Plan name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :name,
                placeholder: "e.g. House deposit, Emergency fund",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :monthly_amount, "Monthly amount", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm font-medium"><%= currency_symbol %></span>
              <%= f.number_field :monthly_amount,
                    min: 1, step: "0.01",
                    placeholder: "150.00",
                    class: "block w-full rounded-lg border border-gray-300 pl-7 pr-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
            </div>
          </div>

          <div>
            <%= f.label :duration_months, "Duration (months)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.select :duration_months,
                  (1..60).map { |n| ["#{n} month#{"s" if n > 1}", n] },
                  { selected: @plan.duration_months || 12 },
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          </div>
        </div>

        <div>
          <%= f.label :start_date, "Start date", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.date_field :start_date,
                value: @plan.start_date || Date.current.next_month.beginning_of_month,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          <p class="text-xs text-gray-400 mt-1.5">Deductions begin from this date</p>
        </div>
      </div>

      <%# Info callout %>
      <div class="mt-6 rounded-xl bg-primary-50/70 border border-primary-100 px-4 py-3 flex gap-3">
        <svg class="w-4 h-4 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/></svg>
        <p class="text-xs text-primary-700">Your payroll manager will review this plan before deductions begin. You'll receive an email once it's approved.</p>
      </div>

      <div class="flex items-center gap-3 mt-6">
        <%= f.submit "Submit plan",
              class: "bg-primary-500 hover:bg-primary-600 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors cursor-pointer" %>
        <%= link_to "Cancel", employee_savings_plans_path(@current_company.slug),
              class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors px-2 py-2" %>
      </div>
    <% end %>
  </div>
</div>
