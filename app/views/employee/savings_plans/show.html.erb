<%# Employee — Savings Plan Show %>

<%# Breadcrumb %>
<div class="flex items-center gap-2 text-sm text-gray-400 mb-6">
  <%= link_to "Savings Plans", employee_savings_plans_path(@current_company.slug),
        class: "hover:text-gray-600 transition-colors" %>
  <span>/</span>
  <span class="text-gray-700 font-medium"><%= @plan.name %></span>
</div>

<%# Header %>
<div class="flex items-start justify-between gap-4 mb-8">
  <div>
    <div class="flex items-center gap-3 mb-1">
      <h1 class="text-2xl font-semibold text-gray-900"><%= @plan.name %></h1>
      <%= status_badge(@plan.status) %>
    </div>
    <p class="text-sm text-gray-400">
      Plan ID: <%= @plan.id.split("-").first %>
      &middot; Created <%= @plan.created_at.strftime("%d %b %Y") %>
    </p>
  </div>
  <% if @plan.active? || @plan.matured? %>
    <%= link_to new_employee_savings_plan_withdrawal_request_path(@current_company.slug, @plan),
          class: "inline-flex items-center gap-1.5 bg-primary-500 hover:bg-primary-600 text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition-colors shadow-sm flex-shrink-0" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18"/></svg>
      Request withdrawal
    <% end %>
  <% end %>
</div>

<%# Stats grid %>
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
  <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Saved so far</p>
    <p class="text-xl font-bold text-gray-900"><%= gbp(@plan.total_saved) %></p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Target</p>
    <p class="text-xl font-bold text-gray-900"><%= gbp(@plan.target_amount) %></p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Monthly</p>
    <p class="text-xl font-bold text-gray-900"><%= gbp(@plan.monthly_amount) %></p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Duration</p>
    <p class="text-xl font-bold text-gray-900"><%= @plan.duration_months %> <span class="text-base font-medium text-gray-500">mo</span></p>
  </div>
</div>

<%# Progress card %>
<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-sm font-semibold text-gray-900">Progress</h2>
    <span class="text-sm font-semibold text-primary-600"><%= @plan.progress_percentage %>%</span>
  </div>
  <div class="w-full bg-gray-100 rounded-full h-3 mb-4">
    <div class="<%= @plan.matured? ? "bg-blue-500" : "bg-primary-500" %> h-3 rounded-full transition-all"
         style="width: <%= @plan.progress_percentage %>%"></div>
  </div>
  <div class="grid grid-cols-3 gap-4 text-sm">
    <div>
      <p class="text-xs text-gray-400 mb-0.5">Start date</p>
      <p class="font-medium text-gray-900"><%= @plan.start_date.strftime("%d %b %Y") %></p>
    </div>
    <div class="text-center">
      <p class="text-xs text-gray-400 mb-0.5">Months remaining</p>
      <p class="font-medium text-gray-900"><%= [@plan.months_remaining, 0].max %></p>
    </div>
    <div class="text-right">
      <p class="text-xs text-gray-400 mb-0.5">Maturity date</p>
      <p class="font-medium text-gray-900"><%= @plan.maturity_date.strftime("%d %b %Y") %></p>
    </div>
  </div>
</div>

<%# Withdrawal requests %>
<% withdrawals = @plan.withdrawal_requests.order(requested_at: :desc) %>
<% if withdrawals.any? %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
    <div class="px-5 py-4 border-b border-gray-100">
      <h2 class="text-sm font-semibold text-gray-900">Withdrawal Requests</h2>
    </div>
    <table class="min-w-full">
      <thead>
        <tr class="bg-gray-50/70">
          <th class="text-left px-5 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Date</th>
          <th class="text-left px-5 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Amount</th>
          <th class="text-left px-5 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Status</th>
          <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Note</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% withdrawals.each do |wr| %>
          <tr>
            <td class="px-5 py-4 text-sm text-gray-600"><%= wr.requested_at.strftime("%d %b %Y") %></td>
            <td class="px-5 py-4 text-sm font-semibold text-gray-900"><%= gbp(wr.amount) %></td>
            <td class="px-5 py-4"><%= status_badge(wr.status) %></td>
            <td class="px-5 py-4 text-sm text-gray-500"><%= wr.review_note.presence || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%# Transaction history %>
<% txns = @plan.transactions.order(created_at: :desc) %>
<% if txns.any? %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100">
      <h2 class="text-sm font-semibold text-gray-900">Transaction History</h2>
    </div>
    <table class="min-w-full">
      <thead>
        <tr class="bg-gray-50/70">
          <th class="text-left px-5 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Date</th>
          <th class="text-left px-5 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Type</th>
          <th class="text-right px-5 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Amount</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% txns.each do |tx| %>
          <tr>
            <td class="px-5 py-3.5 text-sm text-gray-500"><%= tx.created_at.strftime("%d %b %Y") %></td>
            <td class="px-5 py-3.5 text-sm text-gray-700"><%= kind_label(tx.kind) %></td>
            <td class="px-5 py-3.5 text-sm font-semibold text-right <%= kind_color(tx.kind) %>">
              <%= kind_sign(tx.kind) %><%= gbp(tx.amount) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
