<%# Employee — My Payslips %>

<div class="flex items-center justify-between mb-7">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">My payslips</h1>
    <p class="text-gray-500 text-sm mt-1">Your monthly payslips from <%= @current_company.name %></p>
  </div>
</div>

<% if notice.present? %>
  <div class="mb-5 rounded-xl bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-700"><%= notice %></div>
<% end %>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <% if @payslips.empty? %>
    <div class="flex flex-col items-center justify-center py-16 text-center px-8">
      <div class="w-12 h-12 rounded-2xl bg-gray-100 flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/></svg>
      </div>
      <p class="text-sm font-medium text-gray-700 mb-1">No payslips yet</p>
      <p class="text-xs text-gray-400">Your payslips will appear here once processed.</p>
    </div>
  <% else %>
    <table class="min-w-full">
      <thead>
        <tr class="bg-gray-50/70 border-b border-gray-100">
          <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Period</th>
          <th class="text-right px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden sm:table-cell">Gross</th>
          <th class="text-right px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden sm:table-cell">Deductions</th>
          <th class="text-right px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Net pay</th>
          <th class="text-right px-5 py-3.5"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @payslips.each do |entry| %>
          <tr class="hover:bg-gray-50/60 transition-colors">
            <td class="px-5 py-4">
              <p class="text-sm font-semibold text-gray-900"><%= entry.payroll_run.period_label %></p>
              <p class="text-xs text-gray-400 mt-0.5">
                Paid <%= Date.new(entry.payroll_run.year, entry.payroll_run.month, 25).strftime("%-d %b %Y") %>
              </p>
            </td>
            <td class="px-5 py-4 text-sm text-gray-700 text-right hidden sm:table-cell">
              <%= gbp(entry.total_earnings) %>
            </td>
            <td class="px-5 py-4 text-sm text-red-600 text-right hidden sm:table-cell">
              <%= gbp(entry.total_deductions) %>
            </td>
            <td class="px-5 py-4 text-right">
              <span class="text-sm font-bold text-gray-900"><%= gbp(entry.net_pay) %></span>
            </td>
            <td class="px-5 py-4 text-right">
              <%= link_to "View",
                    employee_payslip_path(@current_company.slug, entry),
                    class: "text-xs font-semibold text-primary-600 hover:text-primary-700" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
