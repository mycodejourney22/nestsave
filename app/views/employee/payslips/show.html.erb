<%# Employee — Payslip %>

<div class="flex items-center gap-2 text-sm text-gray-400 mb-7">
  <%= link_to "My payslips", employee_payslips_path(@current_company.slug), class: "hover:text-gray-600 transition-colors" %>
  <span>/</span>
  <span class="text-gray-700 font-medium"><%= @run.period_label %></span>
</div>

<%# Dark header %>
<div class="rounded-xl overflow-hidden mb-6 bg-gradient-to-br from-[#0f1a14] to-[#1D9E75]/80 text-white">
  <div class="px-6 py-5 flex items-start justify-between">
    <div>
      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Payslip</p>
      <h1 class="text-2xl font-bold text-white"><%= @run.period_label %></h1>
      <p class="text-white/60 text-sm mt-0.5"><%= @current_company.name %></p>
    </div>
    <div class="text-right">
      <p class="text-white/50 text-xs uppercase tracking-wider mb-1">Net pay</p>
      <p class="text-3xl font-bold text-white"><%= gbp(@entry.net_pay) %></p>
      <p class="text-white/50 text-xs mt-1">
        Payment date: <%= Date.new(@run.year, @run.month, 25).strftime("%-d %b %Y") %>
      </p>
    </div>
  </div>
</div>

<%# Employee info band %>
<div class="bg-white rounded-xl border border-gray-200 shadow-sm px-6 py-4 mb-5 grid grid-cols-2 sm:grid-cols-4 gap-4">
  <div>
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-0.5">Employee</p>
    <p class="text-sm font-semibold text-gray-900"><%= @entry.display_name %></p>
  </div>
  <div>
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-0.5">Job title</p>
    <p class="text-sm text-gray-700"><%= @profile.job_title.presence || "—" %></p>
  </div>
  <div>
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-0.5">Team</p>
    <p class="text-sm text-gray-700"><%= @profile.team&.name || "Company-wide" %></p>
  </div>
  <div>
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-0.5">Employee no.</p>
    <p class="text-sm text-gray-700"><%= @profile.employee_number.presence || "—" %></p>
  </div>
</div>

<%# Earnings %>
<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-4">
  <div class="px-5 py-3.5 bg-gray-50/70 border-b border-gray-100">
    <h2 class="text-sm font-semibold text-gray-900">Earnings</h2>
  </div>
  <table class="min-w-full">
    <tbody class="divide-y divide-gray-100">
      <% @earnings.each do |item| %>
        <tr>
          <td class="px-5 py-3.5 text-sm text-gray-700"><%= item.label %></td>
          <td class="px-5 py-3.5 text-sm font-medium text-gray-900 text-right"><%= gbp(item.amount) %></td>
        </tr>
      <% end %>
    </tbody>
    <tfoot>
      <tr class="border-t-2 border-gray-200 bg-gray-50/60">
        <td class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-gray-500">Total earnings</td>
        <td class="px-5 py-3 text-sm font-bold text-gray-900 text-right"><%= gbp(@entry.total_earnings) %></td>
      </tr>
    </tfoot>
  </table>
</div>

<%# Deductions %>
<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-5">
  <div class="px-5 py-3.5 bg-gray-50/70 border-b border-gray-100">
    <h2 class="text-sm font-semibold text-gray-900">Deductions</h2>
  </div>
  <table class="min-w-full">
    <tbody class="divide-y divide-gray-100">
      <% @deductions.each do |item| %>
        <tr>
          <td class="px-5 py-3.5 text-sm text-gray-700"><%= item.label %></td>
          <td class="px-5 py-3.5 text-sm font-medium text-red-600 text-right"><%= gbp(item.amount) %></td>
        </tr>
      <% end %>
    </tbody>
    <tfoot>
      <tr class="border-t-2 border-gray-200 bg-gray-50/60">
        <td class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-gray-500">Total deductions</td>
        <td class="px-5 py-3 text-sm font-bold text-red-600 text-right"><%= gbp(@entry.total_deductions) %></td>
      </tr>
    </tfoot>
  </table>
</div>

<%# Net pay banner %>
<div class="rounded-xl bg-emerald-50 border border-emerald-200 px-6 py-4 mb-7 flex items-center justify-between">
  <p class="text-sm font-semibold text-emerald-800">Net pay — <%= @run.period_label %></p>
  <p class="text-2xl font-bold text-emerald-700"><%= gbp(@entry.net_pay) %></p>
</div>

<%# Print button %>
<div class="flex items-center gap-3">
  <button onclick="window.print()"
          class="inline-flex items-center gap-2 bg-white border border-gray-200 hover:border-gray-300 text-gray-700 px-4 py-2.5 rounded-xl text-sm font-medium transition-colors shadow-sm">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z"/></svg>
    Print / Download
  </button>
  <%= link_to "Back to payslips",
        employee_payslips_path(@current_company.slug),
        class: "text-sm font-medium text-gray-600 hover:text-gray-800" %>
</div>
