<%# Employee Dashboard %>

<%# ── Profile band ─────────────────────────────────────────────── %>
<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden mb-6">
  <div class="bg-gradient-to-r from-primary-500 to-primary-600 px-6 py-5">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
        <span class="text-white text-lg font-bold">
          <%= current_user.full_name.split.map { |w| w[0] }.first(2).join.upcase %>
        </span>
      </div>
      <div class="flex-1 min-w-0">
        <h1 class="text-white text-lg font-bold leading-tight"><%= current_user.full_name %></h1>
        <p class="text-primary-100 text-sm mt-0.5">
          <% if @profile&.job_title.present? %>
            <%= @profile.job_title %>
            <% if @current_team %>
              &middot; <%= @current_team.name %>
            <% end %>
          <% else %>
            <%= @current_company.name %>
          <% end %>
        </p>
      </div>
      <% if @current_salary %>
        <div class="bg-white/15 rounded-xl px-4 py-2 text-center flex-shrink-0 hidden sm:block">
          <p class="text-white/70 text-xs mb-0.5">Current salary</p>
          <p class="text-white text-base font-bold text-emerald-300"><%= gbp(@current_salary) %></p>
        </div>
      <% end %>
    </div>
  </div>
  <% if @profile %>
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 px-6 py-3 bg-gray-50/60 border-t border-gray-100 text-xs text-gray-500">
      <% if @profile.employee_number.present? %>
        <span><span class="font-medium text-gray-700">Employee #</span> <%= @profile.employee_number %></span>
      <% end %>

      <% if @profile.employment_type.present? %>
        <span><span class="font-medium text-gray-700">Type</span> <%= @profile.employment_type_label %></span>
      <% end %>
      <% if @current_salary %>
        <span class="sm:hidden"><span class="font-medium text-gray-700">Salary</span> <%= gbp(@current_salary) %>/mo</span>
      <% end %>
    </div>
  <% end %>
</div>

<%# ── Leave balances ───────────────────────────────────────────── %>
<div class="mb-7">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-base font-semibold text-gray-900">Leave balances</h2>
    <%= link_to "Request leave",
          new_employee_leave_request_path(@current_company.slug),
          class: "inline-flex items-center gap-1 text-xs font-medium text-primary-600 hover:text-primary-700" %>
  </div>

  <% if @leave_balances.empty? %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm px-5 py-6 text-center">
      <p class="text-sm text-gray-400">No leave balances yet. Contact HR to set up your entitlement.</p>
    </div>
  <% else %>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <% @leave_balances.each do |bal| %>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
          <p class="text-xs font-medium text-gray-500 mb-2"><%= bal.leave_type.name %></p>
          <% if bal.leave_type.requires_balance? %>
            <% remaining = bal.remaining_days.to_f
               day_color = if remaining > 7 then "text-emerald-600"
                           elsif remaining >= 3 then "text-amber-500"
                           else "text-red-600"
                           end %>
            <p class="text-2xl font-bold <%= day_color %>"><%= bal.remaining_days.to_i %></p>
            <p class="text-xs text-gray-400 mt-0.5">of <%= bal.total_days.to_i %> days</p>
          <% else %>
            <p class="text-2xl font-bold text-gray-300">—</p>
            <p class="text-xs text-gray-400 mt-0.5">as needed</p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<%# ── This week's rota (only if team + published rota exist) ──── %>
<% if @current_rota %>
  <div class="mb-7">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold text-gray-900">
        <%= @current_team.name %> &middot; <span class="font-normal text-gray-500">week of <%= @current_rota.week_start.strftime("%-d %b") %></span>
      </h2>
      <%= link_to "View full rota",
            employee_rota_path(@current_company.slug, @current_rota),
            class: "text-xs font-medium text-primary-600 hover:text-primary-700" %>
    </div>

    <%
      entries_by_date = @my_entries.index_by(&:work_date)
      week_days = (0..4).map { |i| @current_rota.week_start + i }
    %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-x-auto">
      <div class="grid grid-cols-5 min-w-[320px]">
        <% week_days.each do |day| %>
          <% entry = entries_by_date[day] %>
          <div class="border-r last:border-r-0 border-gray-100 p-4 text-center">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1"><%= day.strftime("%a") %></p>
            <p class="text-xs text-gray-400 mb-2"><%= day.strftime("%-d %b") %></p>
            <% if entry %>
              <p class="text-xs font-semibold text-emerald-700">
                <%= entry.start_time&.strftime("%H:%M") %>–<%= entry.end_time&.strftime("%H:%M") %>
              </p>
            <% else %>
              <p class="text-xs font-medium text-gray-300">Off</p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<div class="h-px bg-gray-100 mb-7"></div>

<%# ── My savings & advances ────────────────────────────────────── %>
<div class="mb-7">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-base font-semibold text-gray-900">My savings &amp; advances</h2>
    <%= link_to "View all →",
          employee_savings_plans_path(@current_company.slug),
          class: "text-xs font-medium text-primary-600 hover:text-primary-700" %>
  </div>

  <% if @active_plans.empty? && @open_advance.nil? %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm px-5 py-8 text-center">
      <p class="text-sm text-gray-500 mb-3">No active savings plans or advances</p>
      <div class="flex items-center justify-center gap-4">
        <%= link_to "Start saving",
              new_employee_savings_plan_path(@current_company.slug),
              class: "text-xs font-medium text-primary-600 hover:text-primary-700" %>
        <span class="text-gray-300">|</span>
        <%= link_to "Apply for advance",
              new_employee_salary_advance_path(@current_company.slug),
              class: "text-xs font-medium text-primary-600 hover:text-primary-700" %>
      </div>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @active_plans.first(3).each do |plan| %>
        <%= link_to employee_savings_plan_path(@current_company.slug, plan),
              class: "block bg-white rounded-xl border border-gray-200 shadow-sm px-5 py-4 hover:border-primary-200 transition-all group" do %>
          <div class="flex items-start justify-between mb-2">
            <div>
              <p class="text-sm font-semibold text-gray-900 group-hover:text-primary-700 transition-colors"><%= plan.name %></p>
              <p class="text-xs text-gray-400 mt-0.5">Matures <%= plan.maturity_date.strftime("%-d %b %Y") %></p>
            </div>
            <div class="text-right flex-shrink-0 ml-4">
              <p class="text-sm font-bold text-gray-900"><%= gbp(plan.monthly_amount) %><span class="text-xs font-normal text-gray-400">/mo</span></p>
              <p class="text-xs text-gray-500 mt-0.5"><%= gbp(plan.total_saved) %> saved</p>
            </div>
          </div>
          <div class="w-full bg-gray-100 rounded-full h-1.5 mb-1">
            <div class="bg-primary-500 h-1.5 rounded-full transition-all" style="width: <%= plan.progress_percentage %>%"></div>
          </div>
          <div class="flex items-center justify-between text-xs text-gray-400">
            <span><%= plan.progress_percentage %>% complete</span>
            <span><%= plan.months_remaining %> months remaining</span>
          </div>
        <% end %>
      <% end %>

      <% if @open_advance %>
        <%
          paid_count  = @open_advance.advance_repayment_schedules.where(status: "paid").count rescue 0
          total_count = @open_advance.repayment_months
          pct         = total_count > 0 ? ((paid_count.to_f / total_count) * 100).round : 0
        %>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm px-5 py-4">
          <div class="flex items-start justify-between mb-2">
            <div>
              <p class="text-sm font-semibold text-gray-900">Open advance &middot; <%= gbp(@open_advance.amount) %></p>
              <p class="text-xs text-gray-400 mt-0.5"><%= @open_advance.repayment_months %> months &middot; <%= gbp(@open_advance.monthly_instalment) %>/mo</p>
            </div>
            <%= status_badge(@open_advance.status) %>
          </div>
          <% if @open_advance.repaying? %>
            <div class="w-full bg-gray-100 rounded-full h-1.5 mb-1">
              <div class="bg-indigo-400 h-1.5 rounded-full" style="width: <%= pct %>%"></div>
            </div>
            <div class="flex items-center justify-between text-xs text-gray-400">
              <span><%= paid_count %> of <%= total_count %> payments made</span>
              <span><%= pct %>% repaid</span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<%# ── Quick links ─────────────────────────────────────────────── %>
<div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
  <%= link_to new_employee_leave_request_path(@current_company.slug),
        class: "bg-white rounded-xl border border-gray-200 shadow-sm px-4 py-4 hover:border-primary-200 hover:shadow-md transition-all group" do %>
    <div class="w-8 h-8 rounded-lg bg-primary-50 flex items-center justify-center mb-2 group-hover:bg-primary-100 transition-colors">
      <svg class="w-4 h-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
    </div>
    <p class="text-xs font-semibold text-gray-800">Request leave</p>
    <p class="text-xs text-gray-400">Submit a request</p>
  <% end %>

  <%= link_to employee_profile_path(@current_company.slug),
        class: "bg-white rounded-xl border border-gray-200 shadow-sm px-4 py-4 hover:border-primary-200 hover:shadow-md transition-all group" do %>
    <div class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center mb-2 group-hover:bg-gray-200 transition-colors">
      <svg class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
    </div>
    <p class="text-xs font-semibold text-gray-800">My profile</p>
    <p class="text-xs text-gray-400">View details</p>
  <% end %>

  <%= link_to employee_rotas_path(@current_company.slug),
        class: "bg-white rounded-xl border border-gray-200 shadow-sm px-4 py-4 hover:border-primary-200 hover:shadow-md transition-all group" do %>
    <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center mb-2 group-hover:bg-blue-100 transition-colors">
      <svg class="w-4 h-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12"/></svg>
    </div>
    <p class="text-xs font-semibold text-gray-800">View rota</p>
    <p class="text-xs text-gray-400">Your schedule</p>
  <% end %>

  <%= link_to employee_documents_path(@current_company.slug),
        class: "bg-white rounded-xl border border-gray-200 shadow-sm px-4 py-4 hover:border-primary-200 hover:shadow-md transition-all group" do %>
    <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center mb-2 group-hover:bg-emerald-100 transition-colors">
      <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
    </div>
    <p class="text-xs font-semibold text-gray-800">My documents</p>
    <p class="text-xs text-gray-400">View files</p>
  <% end %>
</div>
