<%# Employee — New Salary Advance %>

<div class="max-w-lg">
  <div class="flex items-center gap-2 text-sm text-gray-400 mb-7">
    <%= link_to "Salary Advances", employee_salary_advances_path(@current_company.slug),
          class: "hover:text-gray-600 transition-colors" %>
    <span>/</span>
    <span class="text-gray-700 font-medium">New application</span>
  </div>

  <h1 class="text-2xl font-semibold text-gray-900 mb-2">Apply for Salary Advance</h1>
  <p class="text-sm text-gray-500 mb-8">
    Request an advance of up to your monthly salary (<%= gbp(@current_membership.current_salary) %>).
    It will be repaid in equal monthly instalments from your salary.
  </p>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <%= form_with model: @advance,
          url: employee_salary_advances_path(@current_company.slug),
          method: :post do |f| %>

      <% if @advance.errors.any? %>
        <div class="mb-5 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
          <p class="text-sm font-semibold text-red-700 mb-1">Please fix the following:</p>
          <ul class="list-disc list-inside space-y-0.5">
            <% @advance.errors.full_messages.each do |msg| %>
              <li class="text-sm text-red-600"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-5">
        <div>
          <%= f.label :amount, "Advance amount", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm font-medium"><%= currency_symbol %></span>
            <%= f.number_field :amount,
                  min: 1, max: @current_membership.current_salary, step: "0.01",
                  placeholder: "500.00",
                  class: "block w-full rounded-lg border border-gray-300 pl-7 pr-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
          </div>
          <p class="text-xs text-gray-400 mt-1.5">Maximum: <%= gbp(@current_membership.current_salary) %></p>
        </div>

        <div>
          <%= f.label :repayment_months, "Repay over", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <div class="grid grid-cols-3 sm:grid-cols-6 gap-2">
            <% (1..6).each do |n| %>
              <label class="cursor-pointer">
                <%= f.radio_button :repayment_months, n, class: "sr-only peer",
                      id: "repayment_#{n}" %>
                <div class="text-center border border-gray-200 rounded-lg py-2.5 px-2 text-sm
                            peer-checked:border-primary-500 peer-checked:bg-primary-50 peer-checked:text-primary-700
                            hover:border-gray-300 transition-colors select-none">
                  <span class="font-semibold"><%= n %></span>
                  <span class="text-xs block text-gray-400 peer-checked:text-primary-500">mo</span>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <div>
          <%= f.label :reason, "Reason for advance", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_area :reason,
                rows: 4,
                placeholder: "Please briefly explain why you need this advance...",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition resize-none" %>
        </div>
      </div>

      <div class="mt-6 rounded-xl bg-amber-50 border border-amber-100 px-4 py-3 flex gap-3">
        <svg class="w-4 h-4 text-amber-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
        <p class="text-xs text-amber-700">You can only have one open advance at a time. Repayments will be automatically deducted from your salary.</p>
      </div>

      <div class="flex items-center gap-3 mt-6">
        <%= f.submit "Submit application",
              class: "bg-primary-500 hover:bg-primary-600 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors cursor-pointer" %>
        <%= link_to "Cancel", employee_salary_advances_path(@current_company.slug),
              class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors px-2 py-2" %>
      </div>
    <% end %>
  </div>
</div>
