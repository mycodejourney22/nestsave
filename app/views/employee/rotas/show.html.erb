<%# Employee — Rota Show %>

<div class="flex items-center gap-2 text-sm text-gray-400 mb-7">
  <%= link_to "My Rota", employee_rotas_path(@current_company.slug), class: "hover:text-gray-600 transition-colors" %>
  <span>/</span>
  <span class="text-gray-700 font-medium"><%= @rota.week_label %></span>
</div>

<div class="mb-6">
  <h1 class="text-2xl font-semibold text-gray-900"><%= @rota.team.name %> — <%= @rota.week_label %></h1>
  <p class="text-gray-500 text-sm mt-1">Your shifts for this week</p>
</div>

<% entries_by_date = @my_entries.index_by(&:work_date) %>

<% if @my_entries.empty? %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
    <div class="flex flex-col items-center justify-center py-20 text-center px-8">
      <p class="text-sm font-medium text-gray-700">No shifts scheduled</p>
      <p class="text-xs text-gray-400 mt-1">You have no shifts assigned for this week</p>
    </div>
  </div>
<% else %>
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
    <% @days.each do |day| %>
      <% entry = entries_by_date[day] %>
      <% is_today = day == Date.current %>
      <div class="bg-white rounded-xl border <%= is_today ? "border-primary-300 ring-1 ring-primary-200" : "border-gray-200" %> shadow-sm p-4">
        <div class="flex items-center justify-between mb-3">
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= day.strftime("%A") %></p>
            <p class="text-sm font-bold text-gray-900 mt-0.5"><%= day.strftime("%-d %B") %></p>
          </div>
          <% if is_today %>
            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold bg-primary-100 text-primary-700">Today</span>
          <% end %>
        </div>

        <% if entry %>
          <div class="flex items-center gap-2 text-sm text-gray-700 font-medium">
            <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
            </svg>
            <%= entry.start_time&.strftime("%H:%M") %> – <%= entry.end_time&.strftime("%H:%M") %>
          </div>
          <% if entry.notes.present? %>
            <p class="text-xs text-gray-400 mt-1.5"><%= entry.notes %></p>
          <% end %>
          <p class="text-xs text-emerald-600 font-medium mt-2">
            <%= entry.hours %> hr<%= entry.hours == 1 ? "" : "s" %>
          </p>
        <% else %>
          <p class="text-xs text-gray-300 <%= day.saturday? || day.sunday? ? "italic" : "" %>">
            <%= day.saturday? || day.sunday? ? "Weekend" : "No shift" %>
          </p>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
