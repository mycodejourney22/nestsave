<%# Employee — Transactions %>

<div class="flex items-center justify-between mb-7">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Transactions</h1>
    <p class="text-gray-500 text-sm mt-1">Your complete payment ledger</p>
  </div>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <% if @transactions.empty? %>
    <div class="flex flex-col items-center justify-center py-20 text-center px-8">
      <div class="w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center mb-3">
        <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
      </div>
      <p class="text-sm font-medium text-gray-700">No transactions yet</p>
      <p class="text-xs text-gray-400 mt-1">Transactions appear here once your savings deductions or advances are processed</p>
    </div>
  <% else %>
    <table class="min-w-full">
      <thead>
        <tr class="bg-gray-50/70 border-b border-gray-100">
          <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Date</th>
          <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden sm:table-cell">Type</th>
          <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Description</th>
          <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden sm:table-cell">Period</th>
          <th class="text-right px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Amount</th>
          <th class="text-left px-5 py-3.5 text-xs font-semibold uppercase tracking-wider text-gray-400 hidden md:table-cell">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @transactions.each do |tx| %>
          <tr class="hover:bg-gray-50/60 transition-colors">
            <td class="px-5 py-4 text-sm text-gray-500 whitespace-nowrap">
              <%= tx.created_at.strftime("%d %b %Y") %>
            </td>
            <td class="px-5 py-4 hidden sm:table-cell">
              <div class="flex items-center gap-2">
                <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0
                            <%= %w[savings_withdrawal advance_disbursement].include?(tx.kind) ? "bg-red-50" : "bg-emerald-50" %>">
                  <svg class="w-3 h-3 <%= %w[savings_withdrawal advance_disbursement].include?(tx.kind) ? "text-red-500" : "text-emerald-600" %>"
                       fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <% if %w[savings_withdrawal advance_disbursement].include?(tx.kind) %>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18"/>
                    <% else %>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"/>
                    <% end %>
                  </svg>
                </div>
                <span class="text-xs text-gray-500"><%= kind_label(tx.kind) %></span>
              </div>
            </td>
            <td class="px-5 py-4 text-sm text-gray-700 max-w-xs truncate">
              <%= tx.description.presence || kind_label(tx.kind) %>
            </td>
            <td class="px-5 py-4 text-sm text-gray-400 hidden sm:table-cell whitespace-nowrap">
              <%= tx.period_month.strftime("%b %Y") %>
            </td>
            <td class="px-5 py-4 text-sm font-semibold text-right whitespace-nowrap <%= kind_color(tx.kind) %>">
              <%= kind_sign(tx.kind) %><%= gbp(tx.amount) %>
            </td>
            <td class="px-5 py-4 hidden md:table-cell">
              <%= status_badge(tx.status) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="px-5 py-4 border-t border-gray-100 flex items-center justify-between">
      <p class="text-xs text-gray-400">Showing <%= @transactions.size %> transactions</p>
      <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
    </div>
  <% end %>
</div>
