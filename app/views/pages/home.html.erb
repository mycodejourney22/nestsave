<%# NestSave — Public landing page %>

<%# ══ NAV ══════════════════════════════════════════════════════════ %>
<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 h-16 flex items-center justify-between">
    <%# Logo %>
    <div class="flex items-center gap-2.5">
      <div class="w-8 h-8 rounded-lg bg-primary-500 flex items-center justify-center flex-shrink-0">
        <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/>
        </svg>
      </div>
      <span class="text-lg font-bold text-gray-900 tracking-tight">NestSave</span>
    </div>

    <%# Nav actions %>
    <div class="flex items-center gap-3">
      <%= link_to "Sign in", new_user_session_path,
            class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors px-3 py-2" %>
      <%= link_to "Register your company", new_registration_path,
            class: "hidden sm:inline-flex items-center bg-primary-500 hover:bg-primary-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors" %>
    </div>
  </div>
</nav>

<%# ══ HERO ═════════════════════════════════════════════════════════ %>
<section class="relative overflow-hidden bg-gradient-to-b from-primary-900 via-[#0f2a1c] to-[#0d1f15] pt-20 pb-24 sm:pt-28 sm:pb-32">
  <%# Subtle background texture %>
  <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, #1D9E75 0%, transparent 50%), radial-gradient(circle at 80% 20%, #3aba86 0%, transparent 40%)"></div>

  <div class="relative max-w-4xl mx-auto px-5 sm:px-8 text-center">
    <%# Badge %>
    <div class="inline-flex items-center gap-2 bg-primary-500/20 border border-primary-500/30 rounded-full px-4 py-1.5 mb-8">
      <div class="w-1.5 h-1.5 rounded-full bg-primary-400"></div>
      <span class="text-primary-300 text-xs font-semibold tracking-wide uppercase">All in one HR platform</span>
    </div>

    <%# Headline %>
    <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
      HR, payroll and team management<br>
      <span class="text-primary-400">— all in one place</span>
    </h1>

    <%# Subtext %>
    <p class="text-lg text-white/60 max-w-2xl mx-auto mb-10 leading-relaxed">
      NestSave brings together everything you need to run your team — employee records, leave, payroll, rotas, salary advances and savings. No spreadsheets. No WhatsApp threads. Just one clean platform.
    </p>

    <%# CTAs %>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <%= link_to new_registration_path,
            class: "w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-primary-500 hover:bg-primary-400 text-white font-semibold px-8 py-3.5 rounded-xl text-base transition-colors shadow-lg shadow-primary-900/50" do %>
        Get started free
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      <% end %>
      <%= link_to "Sign in to your account", new_user_session_path,
            class: "w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/15 text-white font-semibold px-8 py-3.5 rounded-xl text-base transition-colors border border-white/20" %>
    </div>

    <p class="text-white/30 text-xs mt-5">No credit card required &middot; Free to get started</p>
  </div>
</section>

<%# ══ APP PREVIEW ══════════════════════════════════════════════════ %>
<section class="bg-gray-50 py-16 sm:py-20 overflow-hidden">
  <div class="max-w-5xl mx-auto px-5 sm:px-8">
    <p class="text-center text-xs font-semibold uppercase tracking-widest text-gray-400 mb-10">Everything your team needs in one dashboard</p>

    <%# Mock dashboard preview %>
    <div class="bg-white rounded-2xl border border-gray-200 shadow-2xl shadow-gray-200/60 overflow-hidden">
      <%# Fake browser bar %>
      <div class="bg-gray-100 border-b border-gray-200 px-4 py-3 flex items-center gap-2">
        <div class="flex gap-1.5">
          <div class="w-3 h-3 rounded-full bg-red-400/70"></div>
          <div class="w-3 h-3 rounded-full bg-amber-400/70"></div>
          <div class="w-3 h-3 rounded-full bg-green-400/70"></div>
        </div>
        <div class="flex-1 mx-4">
          <div class="bg-white rounded-md border border-gray-200 px-3 py-1 text-xs text-gray-400 max-w-xs mx-auto text-center">nestsave.co/acme/admin/dashboard</div>
        </div>
      </div>

      <%# Mock sidebar + content %>
      <div class="flex min-h-[320px]">
        <%# Sidebar %>
        <div class="hidden sm:flex flex-col w-48 bg-[#0f1a14] flex-shrink-0 p-3 gap-0.5">
          <div class="flex items-center gap-2 px-3 py-3 mb-2">
            <div class="w-5 h-5 rounded bg-primary-500 flex-shrink-0"></div>
            <span class="text-white text-xs font-bold">NestSave</span>
          </div>
          <div class="bg-[#1D9E75] rounded-md px-3 py-2 text-white text-xs font-medium">Dashboard</div>
          <div class="px-3 py-1.5 text-[10px] text-white/30 font-semibold uppercase tracking-wider mt-2">People</div>
          <div class="px-3 py-2 text-[#8aaa95] text-xs">Employees</div>
          <div class="px-3 py-1.5 text-[10px] text-white/30 font-semibold uppercase tracking-wider mt-1">Payroll</div>
          <div class="px-3 py-2 text-[#8aaa95] text-xs">Team members</div>
          <div class="px-3 py-2 text-[#8aaa95] text-xs">Departments</div>
        </div>

        <%# Main content area %>
        <div class="flex-1 p-5 bg-gray-50/50">
          <p class="text-sm font-semibold text-gray-900 mb-4">Pending actions</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-5">
            <div class="bg-white rounded-xl border border-gray-200 p-3 shadow-sm">
              <p class="text-[10px] text-gray-400 uppercase tracking-wide mb-1">Savings plans</p>
              <p class="text-xl font-bold text-gray-900">4</p>
              <p class="text-[10px] text-amber-600 font-medium mt-0.5">Awaiting approval</p>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 p-3 shadow-sm">
              <p class="text-[10px] text-gray-400 uppercase tracking-wide mb-1">Advances</p>
              <p class="text-xl font-bold text-gray-900">2</p>
              <p class="text-[10px] text-amber-600 font-medium mt-0.5">Awaiting approval</p>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 p-3 shadow-sm hidden sm:block">
              <p class="text-[10px] text-gray-400 uppercase tracking-wide mb-1">Employees</p>
              <p class="text-xl font-bold text-gray-900">28</p>
              <p class="text-[10px] text-emerald-600 font-medium mt-0.5">Active</p>
            </div>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="px-4 py-3 border-b border-gray-100">
              <p class="text-xs font-semibold text-gray-700">Recent requests</p>
            </div>
            <% [["Sarah Johnson", "Savings plan", "£200/mo", "pending"],
                ["Marcus Lee",    "Salary advance", "£1,500", "approved"],
                ["Priya Patel",   "Savings plan", "£150/mo", "pending"]].each do |name, type, amount, status| %>
              <div class="flex items-center gap-3 px-4 py-2.5 border-b border-gray-50 last:border-0">
                <div class="w-6 h-6 rounded-full bg-primary-100 flex items-center justify-center flex-shrink-0">
                  <span class="text-primary-700 text-[9px] font-bold"><%= name.split.map { |w| w[0] }.join %></span>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-medium text-gray-800 truncate"><%= name %></p>
                  <p class="text-[10px] text-gray-400"><%= type %> &middot; <%= amount %></p>
                </div>
                <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full <%= status == "approved" ? "bg-emerald-50 text-emerald-700" : "bg-amber-50 text-amber-700" %>"><%= status.capitalize %></span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ══ FEATURES ══════════════════════════════════════════════════════ %>
<section class="py-20 sm:py-24 bg-white">
  <div class="max-w-5xl mx-auto px-5 sm:px-8">
    <div class="text-center mb-14">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Everything in one place</h2>
      <p class="text-gray-500 text-lg max-w-xl mx-auto">From onboarding to monthly payroll — NestSave handles the admin so your team can focus on people.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <%# 1 — Employee records %>
      <div class="bg-gray-50 rounded-2xl p-7 border border-gray-100">
        <div class="w-10 h-10 rounded-xl bg-primary-100 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Employee records</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Manage your team in one place — profiles, salaries, documents and history.</p>
      </div>

      <%# 2 — Leave management %>
      <div class="bg-gray-50 rounded-2xl p-7 border border-gray-100">
        <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Leave management</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Annual, sick and maternity leave — requests, approvals and balances all handled for you.</p>
      </div>

      <%# 3 — Payroll & payslips %>
      <div class="bg-gray-50 rounded-2xl p-7 border border-gray-100">
        <div class="w-10 h-10 rounded-xl bg-violet-100 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Payroll &amp; payslips</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Generate payslips and payroll summaries every month in minutes.</p>
      </div>

      <%# 4 — Rota scheduling %>
      <div class="bg-gray-50 rounded-2xl p-7 border border-gray-100">
        <div class="w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Rota scheduling</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Publish weekly rotas to your team so everyone knows where they need to be.</p>
      </div>

      <%# 5 — Salary advances %>
      <div class="bg-gray-50 rounded-2xl p-7 border border-gray-100">
        <div class="w-10 h-10 rounded-xl bg-rose-100 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-rose-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Salary advances</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Employees request advances, you approve — repayments tracked automatically.</p>
      </div>

      <%# 6 — Employee savings %>
      <div class="bg-gray-50 rounded-2xl p-7 border border-gray-100">
        <div class="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Employee savings</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Let staff save directly from their salary with full visibility for HR.</p>
      </div>
    </div>
  </div>
</section>

<%# ══ HOW IT WORKS ═══════════════════════════════════════════════════ %>
<section class="py-20 sm:py-24 bg-gray-50 border-t border-gray-100">
  <div class="max-w-4xl mx-auto px-5 sm:px-8">
    <div class="text-center mb-14">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Up and running in minutes</h2>
      <p class="text-gray-500 text-lg">No integrations, no complex setup — just a clean platform your team can use from day one.</p>
    </div>

    <div class="grid sm:grid-cols-3 gap-8">
      <% [
        ["1", "Register your company", "Create your account and configure your company details, currency and payroll day in a single form."],
        ["2", "Invite your team", "Send invitation links to employees. They set up their own profiles and can start applying for savings plans or advances right away."],
        ["3", "Approve and track", "Review requests from a clean HR dashboard. Approve savings plans, disburse advances, and export deductions each payroll cycle."]
      ].each do |num, title, desc| %>
        <div class="flex flex-col items-start">
          <div class="w-10 h-10 rounded-full bg-primary-500 flex items-center justify-center mb-5 flex-shrink-0">
            <span class="text-white text-sm font-bold"><%= num %></span>
          </div>
          <h3 class="text-base font-semibold text-gray-900 mb-2"><%= title %></h3>
          <p class="text-sm text-gray-500 leading-relaxed"><%= desc %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ══ CTA BANNER ═════════════════════════════════════════════════════ %>
<section class="bg-gradient-to-r from-primary-800 to-primary-700 py-16 sm:py-20">
  <div class="max-w-3xl mx-auto px-5 sm:px-8 text-center">
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">Ready to give your team a better benefit?</h2>
    <p class="text-primary-200 text-lg mb-10">Join companies already using NestSave to support their employees' financial wellbeing.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <%= link_to "Register your company", new_registration_path,
            class: "w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-white text-primary-700 font-semibold px-8 py-3.5 rounded-xl text-base hover:bg-primary-50 transition-colors" %>
      <%= link_to "Sign in to your account", new_user_session_path,
            class: "w-full sm:w-auto inline-flex items-center justify-center text-primary-200 hover:text-white font-medium text-base transition-colors" %>
    </div>
  </div>
</section>

<%# ══ FOOTER ═════════════════════════════════════════════════════════ %>
<footer class="bg-gray-900 py-10">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2.5">
      <div class="w-7 h-7 rounded-md bg-primary-500 flex items-center justify-center flex-shrink-0">
        <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/>
        </svg>
      </div>
      <span class="text-white font-semibold">NestSave</span>
    </div>
    <p class="text-gray-500 text-sm">&copy; <%= Date.current.year %> NestSave. All rights reserved.</p>
  </div>
</footer>
