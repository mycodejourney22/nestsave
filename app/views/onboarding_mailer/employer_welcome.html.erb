<!-- Greeting -->
<p style="margin:0 0 20px;font-family:Arial,Helvetica,sans-serif;font-size:15px;color:#374151;line-height:1.6;">
  Hi <%= @first_name %>,
</p>
<p style="margin:0 0 20px;font-family:Arial,Helvetica,sans-serif;font-size:15px;color:#374151;line-height:1.6;">
  Welcome to NestSave. You've just taken the first step toward managing your team without the spreadsheets and WhatsApp chaos.
</p>
<p style="margin:0 0 20px;font-family:Arial,Helvetica,sans-serif;font-size:15px;font-weight:600;color:#111827;">
  Here's how to get started in 3 simple steps:
</p>

<!-- Steps -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:0 0 24px;">
  <tr>
    <td style="padding:0 0 16px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
             style="background-color:#f3faf7;border-left:3px solid #1D9E75;border-radius:0 6px 6px 0;">
        <tr>
          <td style="padding:14px 18px;">
            <p style="margin:0 0 4px;font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:700;color:#1D9E75;">1. Create your first team</p>
            <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;line-height:1.5;">Group your staff by department, location or role — however your business is structured.</p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding:0 0 16px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
             style="background-color:#f3faf7;border-left:3px solid #1D9E75;border-radius:0 6px 6px 0;">
        <tr>
          <td style="padding:14px 18px;">
            <p style="margin:0 0 4px;font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:700;color:#1D9E75;">2. Invite your employees</p>
            <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;line-height:1.5;">Add your team members and they'll receive an invite to set up their account.</p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding:0 0 24px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
             style="background-color:#f3faf7;border-left:3px solid #1D9E75;border-radius:0 6px 6px 0;">
        <tr>
          <td style="padding:14px 18px;">
            <p style="margin:0 0 4px;font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:700;color:#1D9E75;">3. Set up leave types</p>
            <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;line-height:1.5;">Configure annual, sick and maternity leave so your team can start making requests straight away.</p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<p style="margin:0 0 24px;font-family:Arial,Helvetica,sans-serif;font-size:15px;color:#374151;line-height:1.6;">
  Your dashboard is waiting at <a href="https://nestsave.app" style="color:#1D9E75;text-decoration:none;">nestsave.app</a>
</p>

<!-- CTA -->
<table cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:0 0 28px;">
  <tr>
    <td style="border-radius:6px;background-color:#1D9E75;" class="btn-td">
      <a href="<%= @dashboard_url %>"
         style="display:inline-block;padding:13px 28px;font-family:Arial,Helvetica,sans-serif;
                font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;
                border-radius:6px;mso-padding-alt:0;line-height:1.2;">
        Get started &rarr;
      </a>
    </td>
  </tr>
</table>

<p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#9ca3af;line-height:1.5;">
  Any questions? Just reply to this email.<br>
  &mdash; The NestSave Team
</p>
