<!-- Greeting -->
<p style="margin:0 0 20px;font-family:Arial,Helvetica,sans-serif;font-size:15px;color:#374151;line-height:1.6;">
  Hi <%= @first_name %>,
</p>
<p style="margin:0 0 20px;font-family:Arial,Helvetica,sans-serif;font-size:15px;color:#374151;line-height:1.6;">
  You've been on NestSave for a few days now — we'd love to know how it's going.
</p>
<p style="margin:0 0 24px;font-family:Arial,Helvetica,sans-serif;font-size:15px;color:#374151;line-height:1.6;">
  If everything is set up and running smoothly, brilliant. If you hit a wall or something isn't working the way you expected, reply to this email and tell us. We read every reply and we're still building — your feedback directly shapes what we build next.
</p>

<p style="margin:0 0 16px;font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:600;color:#111827;">
  A few things worth exploring if you haven't already:
</p>

<!-- Feature list -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:0 0 28px;">
  <tr>
    <td style="padding:0 0 10px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
        <tr>
          <td width="28" style="vertical-align:top;padding-top:1px;">
            <div style="width:20px;height:20px;border-radius:50%;background-color:#1D9E75;display:inline-block;text-align:center;line-height:20px;">
              <span style="font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#ffffff;">&#10003;</span>
            </div>
          </td>
          <td style="padding-left:8px;vertical-align:top;">
            <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#374151;line-height:1.5;">
              <strong>Payroll summary</strong> — run your first monthly payroll report and generate payslips for your team
            </p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding:0 0 10px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
        <tr>
          <td width="28" style="vertical-align:top;padding-top:1px;">
            <div style="width:20px;height:20px;border-radius:50%;background-color:#1D9E75;display:inline-block;text-align:center;line-height:20px;">
              <span style="font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#ffffff;">&#10003;</span>
            </div>
          </td>
          <td style="padding-left:8px;vertical-align:top;">
            <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#374151;line-height:1.5;">
              <strong>Rota scheduling</strong> — publish this week's schedule so your team knows where to be
            </p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding:0 0 24px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
        <tr>
          <td width="28" style="vertical-align:top;padding-top:1px;">
            <div style="width:20px;height:20px;border-radius:50%;background-color:#1D9E75;display:inline-block;text-align:center;line-height:20px;">
              <span style="font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#ffffff;">&#10003;</span>
            </div>
          </td>
          <td style="padding-left:8px;vertical-align:top;">
            <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#374151;line-height:1.5;">
              <strong>Salary advances</strong> — employees can now request advances directly through the app
            </p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<!-- CTA -->
<table cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:0 0 28px;">
  <tr>
    <td style="border-radius:6px;background-color:#1D9E75;" class="btn-td">
      <a href="<%= @dashboard_url %>"
         style="display:inline-block;padding:13px 28px;font-family:Arial,Helvetica,sans-serif;
                font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;
                border-radius:6px;mso-padding-alt:0;line-height:1.2;">
        Go to my dashboard &rarr;
      </a>
    </td>
  </tr>
</table>

<p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#9ca3af;line-height:1.5;">
  Thanks for being an early user of NestSave. It means a lot.<br>
  &mdash; The NestSave Team
</p>
