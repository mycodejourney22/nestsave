<%# Set new password page — matches sign-in card style %>

<div class="w-full max-w-sm">
  <%# Logo %>
  <div class="flex flex-col items-center mb-8">
    <div class="w-12 h-12 rounded-2xl bg-primary-500 flex items-center justify-center mb-4">
      <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
      </svg>
    </div>
    <h1 class="text-2xl font-semibold text-white">NestSave</h1>
    <p class="text-white/60 text-sm mt-1">Employee savings &amp; salary advances</p>
  </div>

  <%# Card %>
  <div class="bg-white rounded-2xl shadow-2xl shadow-black/30 p-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-2">Set new password</h2>
    <p class="text-sm text-gray-500 mb-6">Choose a strong password for your account.</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= f.hidden_field :reset_password_token %>

      <% if resource.errors.any? %>
        <div class="mb-5 rounded-lg bg-red-50 border border-red-200 px-3 py-2.5 text-sm text-red-700">
          <ul class="list-disc list-inside space-y-0.5">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-4 mb-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">New password</label>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition",
                placeholder: "••••••••" %>
          <% if @minimum_password_length %>
            <p class="mt-1 text-xs text-gray-400">Minimum <%= @minimum_password_length %> characters</p>
          <% end %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Confirm new password</label>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition",
                placeholder: "••••••••" %>
        </div>
      </div>

      <%= f.submit "Update password",
            class: "w-full bg-primary-500 hover:bg-primary-600 active:bg-primary-700 text-white font-semibold py-2.5 px-4 rounded-lg text-sm transition-colors cursor-pointer" %>
    <% end %>
  </div>

  <p class="text-center text-white/50 text-sm mt-6">
    <%= link_to "← Back to sign in", new_user_session_path,
          class: "text-primary-400 hover:text-primary-300 font-medium transition-colors" %>
  </p>
</div>
