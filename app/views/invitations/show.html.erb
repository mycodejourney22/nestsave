<%# Invitation acceptance page %>

<div class="w-full max-w-md">
  <%# Logo %>
  <div class="flex items-center justify-center gap-2.5 mb-8">
    <div class="w-9 h-9 rounded-xl bg-primary-500 flex items-center justify-center">
      <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/>
      </svg>
    </div>
    <span class="text-white text-xl font-bold tracking-tight">NestSave</span>
  </div>

  <div class="bg-white rounded-2xl shadow-xl border border-white/10 overflow-hidden">
    <%# Header band %>
    <div class="bg-primary-500 px-6 py-5 text-center">
      <p class="text-primary-100 text-sm mb-0.5">You've been invited to join</p>
      <h1 class="text-white text-xl font-bold"><%= @membership.company.name %></h1>
    </div>

    <div class="px-6 py-6">
      <%# Pre-filled identity %>
      <div class="rounded-xl bg-gray-50 border border-gray-100 px-4 py-3.5 mb-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center flex-shrink-0">
            <span class="text-primary-600 text-sm font-semibold">
              <%= @membership.invited_name.to_s.split.map { |w| w[0] }.first(2).join.upcase %>
            </span>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900"><%= @membership.invited_name %></p>
            <p class="text-xs text-gray-400"><%= @membership.invited_email %></p>
          </div>
        </div>
      </div>

      <%# Error messages %>
      <% if flash[:alert].present? %>
        <div class="mb-4 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
          <p class="text-sm text-red-700"><%= flash[:alert] %></p>
        </div>
      <% end %>

      <% if defined?(@user_errors) && @user_errors&.any? %>
        <div class="mb-4 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
          <p class="text-sm font-semibold text-red-700 mb-1">Please fix the following:</p>
          <ul class="list-disc list-inside space-y-0.5">
            <% @user_errors.full_messages.each do |msg| %>
              <li class="text-sm text-red-600"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if @existing_user %>
        <%# Existing user — just needs their password to confirm %>
        <p class="text-sm text-gray-600 mb-5">
          You already have a NestSave account. Enter your password to accept this invitation.
        </p>

        <%= form_with url: accept_invitation_path(token: @membership.invitation_token),
              method: :patch, local: true do |f| %>
          <div class="space-y-4">
            <div>
              <%= f.label :password, "Your password", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
              <%= f.password_field :password,
                    autocomplete: "current-password",
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
            </div>
          </div>

          <div class="mt-5">
            <%= f.submit "Accept invitation",
                  class: "w-full bg-primary-500 hover:bg-primary-600 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors cursor-pointer" %>
          </div>
        <% end %>

      <% else %>
        <%# New user — set a password to create their account %>
        <p class="text-sm text-gray-600 mb-5">
          Create a password to set up your NestSave account and accept this invitation.
        </p>

        <%= form_with url: accept_invitation_path(token: @membership.invitation_token),
              method: :patch, local: true do |f| %>
          <div class="space-y-4">
            <div>
              <%= f.label :password, "Choose a password", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
              <%= f.password_field :password,
                    autocomplete: "new-password",
                    placeholder: "At least 8 characters",
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
            </div>

            <div>
              <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
              <%= f.password_field :password_confirmation,
                    autocomplete: "new-password",
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 transition" %>
            </div>
          </div>

          <div class="mt-5">
            <%= f.submit "Create account & accept",
                  class: "w-full bg-primary-500 hover:bg-primary-600 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors cursor-pointer" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <p class="text-center text-xs text-white/40 mt-6">
    Already have an account?
    <%= link_to "Sign in", new_user_session_path, class: "text-white/70 hover:text-white underline" %>
  </p>
</div>
