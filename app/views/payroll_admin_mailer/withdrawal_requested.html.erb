<!-- Action label -->
<p style="margin:0 0 4px;font-family:Arial,Helvetica,sans-serif;font-size:13px;
           font-weight:600;color:#f59e0b;letter-spacing:0.5px;text-transform:uppercase;">
  Action required
</p>
<h1 style="margin:0 0 24px;font-family:Georgia,'Times New Roman',serif;font-size:22px;
            font-weight:bold;color:#111827;line-height:1.2;">
  Withdrawal request from <%= @employee.full_name %>
</h1>

<!-- Employee block -->
<table cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:0 0 20px;">
  <tr>
    <td style="width:44px;height:44px;border-radius:22px;background-color:#E1F5EE;
               text-align:center;vertical-align:middle;" width="44" height="44">
      <span style="font-family:Arial,Helvetica,sans-serif;font-size:15px;font-weight:700;
                   color:#1D9E75;"><%= initials(@employee.full_name) %></span>
    </td>
    <td style="padding-left:12px;vertical-align:middle;">
      <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:15px;
                 font-weight:700;color:#111827;"><%= @employee.full_name %></p>
      <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;
                 color:#6b7280;"><%= @employee.email %></p>
    </td>
  </tr>
</table>

<!-- Request details -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="background-color:#f3faf7;border-left:3px solid #1D9E75;border-radius:0 6px 6px 0;
              margin:0 0 20px;">
  <tr>
    <td style="padding:16px 20px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                     padding-bottom:8px;width:40%;">Plan</td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                     color:#111827;padding-bottom:8px;"><%= @request.savings_plan.name %></td>
        </tr>
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                     padding-bottom:8px;">Amount requested</td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;
                     color:#1D9E75;padding-bottom:8px;"><%= formatted_currency(@request.amount) %></td>
        </tr>
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                     padding-bottom:8px;">Current balance</td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                     color:#111827;padding-bottom:8px;"><%= formatted_currency(@request.savings_plan.total_saved) %></td>
        </tr>
        <% if @request.reason.present? %>
          <tr>
            <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;">Reason</td>
            <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                       color:#111827;"><%= @request.reason %></td>
          </tr>
        <% end %>
      </table>
    </td>
  </tr>
</table>

<p style="margin:0 0 28px;font-family:Arial,Helvetica,sans-serif;font-size:14px;
           color:#374151;line-height:1.5;">
  Approve or decline this request from your admin dashboard.
</p>

<!-- CTA -->
<table cellpadding="0" cellspacing="0" border="0" role="presentation">
  <tr>
    <td style="border-radius:6px;background-color:#1D9E75;" class="btn-td">
      <a href="<%= @dashboard_url %>"
         style="display:inline-block;padding:12px 24px;font-family:Arial,Helvetica,sans-serif;
                font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;
                border-radius:6px;line-height:1.2;">
        Review in dashboard &rarr;
      </a>
    </td>
  </tr>
</table>
