<!-- Greeting -->
<p style="margin:0 0 4px;font-family:Arial,Helvetica,sans-serif;font-size:13px;
           font-weight:600;color:#1D9E75;letter-spacing:0.5px;text-transform:uppercase;">
  You've been added
</p>
<h1 style="margin:0 0 20px;font-family:Georgia,'Times New Roman',serif;font-size:24px;
            font-weight:bold;color:#111827;line-height:1.2;">
  Hi <%= @invited_name.split.first %>,
</h1>

<p style="margin:0 0 20px;font-family:Arial,Helvetica,sans-serif;font-size:15px;
           color:#374151;line-height:1.6;">
  Great news — <strong><%= @company.name %></strong> has added you to NestSave, their HR platform.
</p>
<p style="margin:0 0 16px;font-family:Arial,Helvetica,sans-serif;font-size:15px;
           color:#374151;line-height:1.6;">
  NestSave is where you'll be able to:
</p>

<!-- Feature list -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="background-color:#f3faf7;border-left:3px solid #1D9E75;border-radius:0 6px 6px 0;
              margin:0 0 24px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0 0 8px;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#374151;line-height:1.5;">
        &#128203; &nbsp;View your employment details and payslips
      </p>
      <p style="margin:0 0 8px;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#374151;line-height:1.5;">
        &#128197; &nbsp;Request and track your leave
      </p>
      <p style="margin:0 0 8px;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#374151;line-height:1.5;">
        &#128197; &nbsp;See your weekly rota
      </p>
      <p style="margin:0 0 8px;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#374151;line-height:1.5;">
        &#128176; &nbsp;Apply for a salary advance if you ever need one
      </p>
      <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#374151;line-height:1.5;">
        &#127974; &nbsp;Set up a savings plan directly from your salary
      </p>
    </td>
  </tr>
</table>

<p style="margin:0 0 20px;font-family:Arial,Helvetica,sans-serif;font-size:15px;
           font-weight:600;color:#111827;line-height:1.6;">
  To get started, set up your password below:
</p>

<!-- CTA button -->
<table cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:0 0 20px;">
  <tr>
    <td style="border-radius:6px;background-color:#1D9E75;" class="btn-td">
      <a href="<%= @accept_url %>"
         style="display:inline-block;padding:13px 28px;font-family:Arial,Helvetica,sans-serif;
                font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;
                border-radius:6px;mso-padding-alt:0;line-height:1.2;">
        Set up my account &rarr;
      </a>
    </td>
  </tr>
</table>

<!-- Expiry notice -->
<p style="margin:0 0 20px;font-family:Arial,Helvetica,sans-serif;font-size:13px;
           color:#9ca3af;line-height:1.5;">
  This link expires in 48&nbsp;hours. If it expires, ask your HR manager to resend the invite.
</p>

<!-- Link fallback -->
<p style="margin:0 0 4px;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#9ca3af;">
  If the button doesn't work, copy and paste this link:
</p>
<p style="margin:0 0 24px;font-family:Arial,Helvetica,sans-serif;font-size:12px;
           color:#6b7280;word-break:break-all;"><%= @accept_url %></p>

<hr style="border:none;border-top:1px solid #e5e7eb;margin:0 0 20px;" />

<p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#9ca3af;
           line-height:1.5;">
  Welcome to the team on NestSave — we hope you find it useful.<br>
  &mdash; The NestSave Team
</p>
