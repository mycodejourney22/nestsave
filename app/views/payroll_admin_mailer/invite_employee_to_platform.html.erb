<!-- Headline -->
<p style="margin:0 0 4px;font-family:Arial,Helvetica,sans-serif;font-size:13px;
           font-weight:600;color:#1D9E75;letter-spacing:0.5px;text-transform:uppercase;">
  You have been invited
</p>
<h1 style="margin:0 0 20px;font-family:Georgia,'Times New Roman',serif;font-size:24px;
            font-weight:bold;color:#111827;line-height:1.2;">
  Join <%= @company.name %> on NestSave
</h1>

<p style="margin:0 0 20px;font-family:Arial,Helvetica,sans-serif;font-size:15px;
           color:#374151;line-height:1.6;">
  Hi <%= @invited_name.split.first %>,
</p>
<p style="margin:0 0 20px;font-family:Arial,Helvetica,sans-serif;font-size:15px;
           color:#374151;line-height:1.6;">
  <strong><%= @membership.inviter&.full_name || @company.name %></strong> has set you up on NestSave —
  <%= @company.name %>'s HR and payroll savings platform. Click the button below to create
  your account and get started.
</p>

<!-- Details box -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation"
       style="background-color:#f3faf7;border-left:3px solid #1D9E75;border-radius:0 6px 6px 0;
              margin:0 0 24px;">
  <tr>
    <td style="padding:16px 20px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                     padding-bottom:8px;width:38%;">Your name</td>
          <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                     color:#111827;padding-bottom:8px;"><%= @invited_name %></td>
        </tr>
        <% if @profile&.job_title.present? %>
          <tr>
            <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                       padding-bottom:8px;">Role</td>
            <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                       color:#111827;padding-bottom:8px;">
              <%= @profile.job_title %><% if @profile.department.present? %> &bull; <%= @profile.department %><% end %>
            </td>
          </tr>
        <% end %>
        <% if @profile&.current_salary.present? %>
          <tr>
            <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;
                       padding-bottom:8px;">Salary</td>
            <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                       color:#111827;padding-bottom:8px;"><%= formatted_currency(@profile.current_salary) %>/mo</td>
          </tr>
        <% end %>
        <% if @profile&.employment_type.present? %>
          <tr>
            <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#6b7280;">Employment</td>
            <td style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:600;
                       color:#111827;"><%= @profile.employment_type_label %></td>
          </tr>
        <% end %>
      </table>
    </td>
  </tr>
</table>

<!-- Expiry notice -->
<p style="margin:0 0 24px;font-family:Arial,Helvetica,sans-serif;font-size:13px;
           color:#9ca3af;line-height:1.5;">
  &#9203; This invitation link expires in 48&nbsp;hours.
</p>

<!-- CTA button -->
<table cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:0 0 28px;">
  <tr>
    <td style="border-radius:6px;background-color:#1D9E75;" class="btn-td">
      <a href="<%= @accept_url %>"
         style="display:inline-block;padding:13px 28px;font-family:Arial,Helvetica,sans-serif;
                font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;
                border-radius:6px;mso-padding-alt:0;line-height:1.2;">
        Set up your account &rarr;
      </a>
    </td>
  </tr>
</table>

<!-- Link fallback -->
<p style="margin:0 0 8px;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#9ca3af;">
  If the button doesn't work, copy and paste this link:
</p>
<p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:12px;
           color:#6b7280;word-break:break-all;"><%= @accept_url %></p>

<hr style="border:none;border-top:1px solid #e5e7eb;margin:24px 0;" />

<p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#9ca3af;
           line-height:1.5;">
  If you weren't expecting this invitation, you can safely ignore this email.
  No account will be created without your action.
</p>
