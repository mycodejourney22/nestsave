<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <title>NestSave</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap" rel="stylesheet">

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: {
              50:  "#edfaf4", 100: "#d3f4e3", 200: "#aae8ca",
              300: "#72d5aa", 400: "#3aba86", 500: "#1D9E75",
              600: "#157f5d", 700: "#12664c", 800: "#10503d", 900: "#0d4233"
            }
          },
          fontFamily: { sans: ["DM Sans", "ui-sans-serif", "system-ui", "sans-serif"] }
        }
      }
    }
  </script>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>

<body class="h-full bg-gray-50 font-sans antialiased text-gray-900">

<% if user_signed_in? && !devise_controller? && defined?(@current_company) && @current_company %>

  <%# ── Authenticated shell ─────────────────────────────────────── %>
  <div class="min-h-full" data-controller="sidebar">

    <%# Mobile overlay %>
    <div class="hidden fixed inset-0 bg-black/50 z-20"
         data-sidebar-target="overlay"
         data-action="click->sidebar#close"></div>

    <%# Sidebar %>
    <aside class="fixed inset-y-0 left-0 w-60 bg-[#0f1a14] flex flex-col z-30
                  -translate-x-full lg:translate-x-0 transition-transform duration-300"
           data-sidebar-target="sidebar">

      <%# Logo / company %>
      <div class="flex items-center gap-3 px-5 py-5 border-b border-white/10">
        <div class="w-8 h-8 rounded-lg bg-primary-500 flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-white text-sm font-semibold leading-none">NestSave</p>
          <p class="text-white/45 text-xs mt-1 truncate"><%= @current_company.name %></p>
        </div>
      </div>

      <%# Navigation %>
      <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">

        <%# ── Employee section — visible to all ── %>
        <% if @current_membership&.hr_or_above? %>
          <%= link_to admin_dashboard_path(@current_company.slug),
                class: nav_link_class(admin_dashboard_path(@current_company.slug)) do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
            <span>Dashboard</span>
          <% end %>
        <% else %>
          <%= link_to employee_dashboard_path(@current_company.slug),
                class: nav_link_class(employee_dashboard_path(@current_company.slug)) do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
            <span>Dashboard</span>
          <% end %>
        <% end %>

        <p class="px-3 pt-5 pb-1 text-[10px] font-semibold uppercase tracking-widest text-white/30">My Finances</p>

        <%= link_to employee_savings_plans_path(@current_company.slug),
              class: nav_link_class(employee_savings_plans_path(@current_company.slug)) do %>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span>Savings Plans</span>
        <% end %>

        <%= link_to employee_salary_advances_path(@current_company.slug),
              class: nav_link_class(employee_salary_advances_path(@current_company.slug)) do %>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>
          <span>Salary Advances</span>
        <% end %>

        <%= link_to employee_transactions_path(@current_company.slug),
              class: nav_link_class(employee_transactions_path(@current_company.slug)) do %>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
          <span>Transactions</span>
        <% end %>

        <p class="px-3 pt-5 pb-1 text-[10px] font-semibold uppercase tracking-widest text-white/30">My Profile</p>

        <%= link_to employee_profile_path(@current_company.slug),
              class: nav_link_class(employee_profile_path(@current_company.slug)) do %>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
          <span>My profile</span>
        <% end %>

        <%= link_to employee_documents_path(@current_company.slug),
              class: nav_link_class(employee_documents_path(@current_company.slug)) do %>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
          <span>My documents</span>
        <% end %>

        <%# ── HR & Payroll — hr_admin and above ── %>
        <% if @current_membership&.hr_or_above? %>
          <p class="px-3 pt-5 pb-1 text-[10px] font-semibold uppercase tracking-widest text-white/30">People</p>

          <%= link_to admin_employee_profiles_path(@current_company.slug),
                class: nav_link_class(admin_employee_profiles_path(@current_company.slug)) do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
            <span>Employees</span>
          <% end %>

          <p class="px-3 pt-5 pb-1 text-[10px] font-semibold uppercase tracking-widest text-white/30">Payroll</p>

          <%= link_to admin_company_memberships_path(@current_company.slug),
                class: nav_link_class(admin_company_memberships_path(@current_company.slug)) do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/></svg>
            <span>Team members</span>
          <% end %>

          <%= link_to admin_departments_path(@current_company.slug),
                class: nav_link_class(admin_departments_path(@current_company.slug)) do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>
            <span>Departments</span>
          <% end %>
        <% end %>

        <%# ── Studio — studio_manager and above ── %>
        <% if @current_membership&.studio_manager_or_above? %>
          <p class="px-3 pt-5 pb-1 text-[10px] font-semibold uppercase tracking-widest text-white/30">Studio</p>
          <span class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-white/30 cursor-not-allowed"
                title="Coming soon">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z"/></svg>
            <span>Studio <span class="text-[10px] ml-1 opacity-60">Coming soon</span></span>
          </span>
        <% end %>

        <%# ── Settings — super_admin only ── %>
        <% if @current_membership&.super_admin? %>
          <p class="px-3 pt-5 pb-1 text-[10px] font-semibold uppercase tracking-widest text-white/30">Company</p>
          <span class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-white/30 cursor-not-allowed"
                title="Coming soon">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>Settings <span class="text-[10px] ml-1 opacity-60">Coming soon</span></span>
          </span>
        <% end %>

      </nav>

      <%# User footer %>
      <div class="px-4 py-4 border-t border-white/10">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-primary-500/25 flex items-center justify-center flex-shrink-0">
            <span class="text-primary-300 text-xs font-semibold">
              <%= current_user.full_name.split.map { |w| w[0] }.first(2).join.upcase %>
            </span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-white text-xs font-medium truncate"><%= current_user.full_name %></p>
            <p class="text-white/40 text-xs truncate"><%= current_user.email %></p>
          </div>
          <%= link_to destroy_user_session_path,
                data: { turbo_method: :delete },
                title: "Sign out",
                class: "text-white/35 hover:text-white/70 transition-colors flex-shrink-0 p-1" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/>
            </svg>
          <% end %>
        </div>
      </div>
    </aside>

    <%# Main content area %>
    <div class="lg:ml-60 flex-1 flex flex-col overflow-hidden">

      <%# Mobile top bar %>
      <header class="sticky top-0 z-10 bg-white/95 backdrop-blur border-b border-gray-200 lg:hidden">
        <div class="flex items-center gap-3 px-4 h-14">
          <button data-action="click->sidebar#toggle"
                  class="p-1.5 -ml-1.5 text-gray-500 hover:text-gray-800 hover:bg-gray-100 rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
            </svg>
          </button>
          <div class="flex items-center gap-2">
            <div class="w-5 h-5 rounded bg-primary-500 flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/>
              </svg>
            </div>
            <span class="text-sm font-semibold text-gray-900">NestSave</span>
          </div>
        </div>
      </header>

      <%# Flash %>
      <div id="flash_messages">
        <%= render "shared/flash" %>
      </div>

      <%# Page content %>
      <main class="flex-1 p-5 sm:p-6 lg:p-8">
        <%= yield %>
      </main>
    </div>
  </div>

<% else %>
  <%# ── Auth / public layout ──────────────────────────────────── %>
  <div class="min-h-screen bg-gradient-to-br from-primary-900 via-primary-800 to-[#0D2318] flex flex-col items-center justify-center px-4 py-12">
    <%= render "shared/flash" %>
    <%= yield %>
  </div>
<% end %>

<%# ── Global Turbo Frame modal ─────────────────────────────── %>
<div id="modal-wrapper"
     class="hidden fixed inset-0 z-50"
     data-controller="modal"
     data-modal-target="wrapper">
  <div class="absolute inset-0 bg-gray-900/60 backdrop-blur-sm"
       data-action="click->modal#close"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4 pointer-events-none">
    <turbo-frame id="modal"
                 class="relative w-full max-w-md bg-white rounded-2xl shadow-2xl pointer-events-auto overflow-hidden">
    </turbo-frame>
  </div>
</div>

</body>
</html>
